<%- include('../partials/frontend-head', { pageTitle: null }) %>
<%- include('../partials/frontend-header', { currentPath: '/' }) %>

<div class="container" style="max-width:860px;padding:48px 24px">
  <% if (posts.length === 0) { %>
    <div class="empty-state">
      <div class="icon">📝</div>
      <h2>Sem posts publicados</h2>
      <p>Em breve haverá conteúdo aqui.</p>
    </div>
  <% } else { %>
    <div class="posts-list">
      <% posts.forEach(function(post) { %>
        <article class="post-card">
          <div class="post-date">
            <%= new Date(post.post_date).toLocaleDateString('pt-PT', {day:'numeric',month:'long',year:'numeric'}) %>
          </div>
          <h2><a href="/post/<%= post.post_name %>"><%= post.post_title %></a></h2>
          <p class="post-excerpt">
            <% if (post.post_excerpt) { %>
              <%= post.post_excerpt %>
            <% } else { %>
              <%= post.post_content.replace(/[#*`>_\[\]]/g,'').substring(0,180) %>...
            <% } %>
          </p>
          <a class="read-more" href="/post/<%= post.post_name %>">Ler mais →</a>
        </article>
      <% }) %>
    </div>

    <% if (totalPages > 1) { %>
      <nav>
        <ul class="pagination justify-content-center">
          <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
            <a class="page-link" href="/?page=<%= currentPage-1 %>">←</a>
          </li>
          <% for(var i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= i === currentPage ? 'active' : '' %>">
              <a class="page-link" href="/?page=<%= i %>"><%= i %></a>
            </li>
          <% } %>
          <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="/?page=<%= currentPage+1 %>">→</a>
          </li>
        </ul>
      </nav>
    <% } %>
  <% } %>
</div>

<%- include('../partials/frontend-footer') %>
