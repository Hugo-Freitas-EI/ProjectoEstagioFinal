<%- include('../partials/frontend-head', { pageTitle: page.post_title }) %>
<%- include('../partials/frontend-header', { currentPath: '/page/' + page.post_name }) %>

<% var _sb = typeof menuLocations !== 'undefined' && menuLocations ? menuLocations.sidebar : null; %>
<div class="container" style="max-width:<%= _sb && _sb.length ? '1140px' : '680px' %>;padding:48px 24px">
<div class="<%= _sb && _sb.length ? 'page-with-sidebar' : '' %>">
<div>
  <article>

    <div class="post-header">
      <h1><%= page.post_title %></h1>
      <% if (page.post_date) { %>
        <div class="post-meta">
          <span>
            <i class="bi bi-calendar3"></i>
            <%= new Date(page.post_date).toLocaleDateString('pt-PT', { day:'numeric', month:'long', year:'numeric' }) %>
          </span>
        </div>
      <% } %>
    </div>

    <div class="post-body"><%- bodyHtml %></div>

  </article>
</div>
<%- include('../partials/frontend-sidebar') %>
</div>
</div>

<%- include('../partials/frontend-footer') %>
