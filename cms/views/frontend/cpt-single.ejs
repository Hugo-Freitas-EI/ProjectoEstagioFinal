<%- include('../partials/frontend-head', { pageTitle: post.post_title, metaDesc: post.post_excerpt }) %>
<%- include('../partials/frontend-header', { currentPath: '/' + postType.name + '/' + post.post_name }) %>

<div class="container" style="max-width:680px;padding:48px 24px">

  <a class="back-link" href="/<%= postType.name %>">← Voltar a <%= postType.label %></a>

  <article>
    <div class="post-header">

      <% if (terms.length) { %>
        <div class="post-terms">
          <% terms.forEach(function(t) { %>
            <span class="post-term-badge"><%= t.name %></span>
          <% }) %>
        </div>
      <% } %>

      <h1><%= post.post_title %></h1>

      <div class="post-meta">
        <% if (post.post_author_name) { %>
          <span><i class="bi bi-person"></i> <%= post.post_author_name %></span>
        <% } %>
        <span>
          <i class="bi bi-calendar3"></i>
          <%= new Date(post.post_date).toLocaleDateString('pt-PT', { day:'numeric', month:'long', year:'numeric' }) %>
        </span>
      </div>

    </div>

    <%# Custom fields — apresentados antes do corpo quando existem %>
    <% if (meta && meta.length) { %>
      <div class="cpt-meta-fields">
        <% meta.forEach(function(f) { %>
          <div class="cpt-meta-row">
            <span class="cpt-meta-label"><%= f.label %></span>
            <span class="cpt-meta-value">
              <% if (f.type === 'url' && f.value) { %>
                <a href="<%= f.value %>" target="_blank" rel="noopener"><%= f.value %></a>
              <% } else if (f.type === 'date' && f.value) { %>
                <%= new Date(f.value).toLocaleDateString('pt-PT', { day:'numeric', month:'long', year:'numeric' }) %>
              <% } else { %>
                <%= f.value || '—' %>
              <% } %>
            </span>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (post.post_content) { %>
      <div class="post-body"><%- bodyHtml %></div>
    <% } %>

    <% if (terms.length) { %>
      <div class="post-tags-footer">
        <i class="bi bi-tag"></i>
        <% terms.forEach(function(t) { %>
          <span class="post-term-badge"><%= t.name %></span>
        <% }) %>
      </div>
    <% } %>

  </article>

  <% if (prev || next) { %>
    <nav class="post-nav" aria-label="Navegação entre entradas">
      <div class="post-nav-prev">
        <% if (prev) { %>
          <a href="/<%= postType.name %>/<%= prev.post_name %>">
            <span class="post-nav-label">← Anterior</span>
            <span class="post-nav-title"><%= prev.post_title %></span>
          </a>
        <% } %>
      </div>
      <div class="post-nav-next">
        <% if (next) { %>
          <a href="/<%= postType.name %>/<%= next.post_name %>">
            <span class="post-nav-label">Seguinte →</span>
            <span class="post-nav-title"><%= next.post_title %></span>
          </a>
        <% } %>
      </div>
    </nav>
  <% } %>

</div>

<%- include('../partials/frontend-footer') %>
