<%- include('../partials/frontend-head', { pageTitle: post.post_title, metaDesc: post.post_excerpt }) %>
<%- include('../partials/frontend-header', { currentPath: '/post/' + post.post_name }) %>

<% var _sb = typeof menuLocations !== 'undefined' && menuLocations ? menuLocations.sidebar : null; %>
<div class="container" style="max-width:<%= _sb && _sb.length ? '1140px' : '680px' %>;padding:48px 24px">
<div class="<%= _sb && _sb.length ? 'page-with-sidebar' : '' %>">
<div>

  <a class="back-link" href="/">← Voltar</a>

  <article>
    <div class="post-header">

      <%# Categorias/termos %>
      <% if (terms.length) { %>
        <div class="post-terms">
          <% terms.forEach(function(t) { %>
            <span class="post-term-badge"><%= t.name %></span>
          <% }) %>
        </div>
      <% } %>

      <h1><%= post.post_title %></h1>

      <%# Meta: autor, data de publicação %>
      <div class="post-meta">
        <% if (post.post_author_name) { %>
          <span><i class="bi bi-person"></i> <%= post.post_author_name %></span>
        <% } %>
        <span>
          <i class="bi bi-calendar3"></i>
          <%= new Date(post.post_date).toLocaleDateString('pt-PT', { day:'numeric', month:'long', year:'numeric' }) %>
        </span>
      </div>

    </div>

    <%# Custom fields %>
    <% if (meta && meta.length) { %>
      <div class="cpt-meta-fields">
        <% meta.forEach(function(f) { %>
          <div class="cpt-meta-row">
            <span class="cpt-meta-label"><%= f.label %></span>
            <span class="cpt-meta-value">
              <% if (f.type === 'url' && f.value) { %>
                <a href="<%= f.value %>" target="_blank" rel="noopener"><%= f.value %></a>
              <% } else if (f.type === 'date' && f.value) { %>
                <%= new Date(f.value).toLocaleDateString('pt-PT', { day:'numeric', month:'long', year:'numeric' }) %>
              <% } else { %>
                <%= f.value || '—' %>
              <% } %>
            </span>
          </div>
        <% }) %>
      </div>
    <% } %>

    <div class="post-body"><%- bodyHtml %></div>

    <%# Rodapé do post: termos como tags %>
    <% if (terms.length) { %>
      <div class="post-tags-footer">
        <i class="bi bi-tag"></i>
        <% terms.forEach(function(t) { %>
          <span class="post-term-badge"><%= t.name %></span>
        <% }) %>
      </div>
    <% } %>

  </article>

</div>
<%- include('../partials/frontend-sidebar') %>
</div>
</div>

<%- include('../partials/frontend-footer') %>
