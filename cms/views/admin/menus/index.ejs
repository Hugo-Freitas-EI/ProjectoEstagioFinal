<%- include('../../partials/admin-layout', { pageTitle: 'Menus', currentPage: 'menus' }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <span class="text-muted"><%= menus.length %> menu(s)</span>
  <a href="/admin/menus/new" class="btn btn-sm btn-primary">
    <i class="bi bi-plus-lg me-1"></i> Novo Menu
  </a>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>Nome</th>
          <th>Slug</th>
          <th class="text-end">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (!menus.length) { %>
          <tr>
            <td colspan="3" class="text-center py-4 text-muted">
              Sem menus. <a href="/admin/menus/new" style="color:var(--accent2)">Criar o primeiro</a>
            </td>
          </tr>
        <% } %>
        <% menus.forEach(function(m) { %>
          <tr>
            <td style="font-weight:500;color:var(--accent2)"><%= m.nome %></td>
            <td class="text-muted" style="font-family:'DM Mono',monospace;font-size:12px"><%= m.slug %></td>
            <td class="text-end">
              <div class="d-flex gap-1 justify-content-end">
                <a href="/admin/menus/<%= m.id %>/edit" class="btn btn-sm btn-outline-secondary">
                  <i class="bi bi-pencil"></i>
                </a>
                <form method="POST" action="/admin/menus/<%= m.id %>/delete"
                  onsubmit="return confirm('Apagar menu e todos os seus itens?')">
                  <button type="submit" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="card mt-4">
  <div class="card-header d-flex align-items-center justify-content-between">
    <span>Localizações de Menu</span>
    <span class="text-muted" style="font-size:12px">Definem onde cada menu aparece no site</span>
  </div>
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>Localização</th>
          <th>Chave</th>
          <th>Menu atribuído</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% locationsWithMenu.forEach(function(loc) { %>
          <tr>
            <td style="font-weight:500">
              <%= loc.label %>
              <% if (loc.system) { %>
                <span class="badge ms-1" style="font-size:10px;background:var(--surface2);color:var(--text2);font-weight:400">sistema</span>
              <% } %>
            </td>
            <td class="text-muted" style="font-family:'DM Mono',monospace;font-size:12px"><%= loc.key %></td>
            <td>
              <% if (loc.assignedMenu) { %>
                <a href="/admin/menus/<%= loc.assignedMenu.id %>/edit" style="color:var(--accent2);font-size:13px">
                  <%= loc.assignedMenu.nome %>
                </a>
              <% } else { %>
                <span class="text-muted" style="font-size:13px">— nenhum —</span>
              <% } %>
            </td>
            <td class="text-end">
              <% if (!loc.system) { %>
                <form method="POST" action="/admin/menus/locations/<%= loc.key %>/delete"
                  onsubmit="return confirm('Remover localização «<%= loc.label %>»?')">
                  <button type="submit" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div class="card-footer">
    <form method="POST" action="/admin/menus/locations/new" class="d-flex gap-2 align-items-end" style="max-width:380px">
      <div style="flex:1">
        <label class="form-label mb-1" style="font-size:12px">Nova localização</label>
        <input type="text" name="label" class="form-control form-control-sm"
          placeholder="Ex: Footer, Sidebar, Rodapé" required>
      </div>
      <button type="submit" class="btn btn-sm btn-primary flex-shrink-0">
        <i class="bi bi-plus-lg me-1"></i> Criar
      </button>
    </form>
    <div class="form-text mt-1">A chave é gerada automaticamente do nome.</div>
  </div>
</div>

<%- include('../../partials/admin-layout-end') %>
