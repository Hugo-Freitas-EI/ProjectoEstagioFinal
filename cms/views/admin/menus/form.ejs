<%- include('../../partials/admin-layout', { pageTitle: pageTitle, currentPage: 'menus' }) %>

<div class="row"><div class="col-lg-5">
  <% if (error) { %><div class="alert alert-danger mb-3"><%= error %></div><% } %>

  <div class="card">
    <div class="card-header">Novo Menu</div>
    <div class="card-body">
      <form method="POST" action="/admin/menus">
        <div class="mb-3">
          <label class="form-label">Nome do menu *</label>
          <input type="text" name="nome" class="form-control" value="<%= menu ? menu.nome : '' %>" required autofocus>
        </div>
        <div class="mb-4">
          <label class="form-label">Slug</label>
          <input type="text" name="slug" class="form-control" value="<%= menu ? menu.slug : '' %>" placeholder="gerado automaticamente">
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i> Criar Menu
          </button>
          <a href="/admin/menus" class="btn btn-outline-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
</div></div>

<%- include('../../partials/admin-layout-end') %>
