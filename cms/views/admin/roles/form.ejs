<%- include('../../partials/admin-layout', { pageTitle: pageTitle, currentPage: 'roles' }) %>

<div class="row justify-content-center">
  <div class="col-lg-9">
    <div class="card">
      <div class="card-body">

        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form method="POST" action="<%= isEdit ? '/admin/roles/' + role.name : '/admin/roles' %>" data-unsaved>

          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <label class="form-label fw-semibold">Label <span class="text-danger">*</span></label>
              <input type="text" name="label" class="form-control"
                value="<%= role && role.label ? role.label : '' %>"
                placeholder="Ex: Moderador" required>
              <div class="form-text">Nome apresentado ao utilizador.</div>
            </div>
            <div class="col-md-6">
              <% if (!isEdit) { %>
                <label class="form-label fw-semibold">Nome interno</label>
                <input type="text" name="name" class="form-control"
                  value="<%= role && role.name ? role.name : '' %>"
                  placeholder="Gerado automaticamente">
                <div class="form-text">Identificador único (letras minúsculas e _).</div>
              <% } else { %>
                <label class="form-label fw-semibold">Nome interno</label>
                <input type="text" class="form-control bg-body-secondary" value="<%= role.name %>" disabled>
              <% } %>
            </div>
          </div>

          <% if (!(isEdit && role && role.name === 'admin')) { %>
          <div class="mb-3">
            <div class="form-check">
              <input type="checkbox" class="form-check-input" id="own_content_only"
                name="own_content_only" value="1"
                <%= (role && role.own_content_only) ? 'checked' : '' %>>
              <label class="form-check-label" for="own_content_only">
                Apenas pode gerir o conteúdo que criou
              </label>
            </div>
          </div>
          <% } %>

          <hr class="my-4">

          <% if (isEdit && role && role.name === 'admin') { %>
            <p class="text-muted">O administrador tem sempre todas as permissões — não é possível editar.</p>
          <% } else { %>
            <% var currentPerms = (role && role.permissions) ? role.permissions : []; %>
            <% function hasPerm(key) { return currentPerms.includes(key); } %>

            <%
              // Juntar CPTs ao grupo "Conteúdo"
              var allGroups = permissionGroups.map(function(g) {
                if (g.key !== 'content') return g;
                var items = g.items.slice();
                (customPostTypes || []).forEach(function(cpt) {
                  items.push({ key: 'cpt.' + cpt.name, label: cpt.label });
                });
                return { key: g.key, label: g.label, items: items };
              });
            %>

            <div class="d-flex flex-column gap-4">
              <% allGroups.forEach(function(group) { %>
                <div class="perm-group" data-group="<%= group.key %>">

                  <!-- Cabeçalho da secção com checkbox geral -->
                  <div class="d-flex align-items-center gap-2 mb-2">
                    <input type="checkbox" class="form-check-input section-toggle"
                      id="sec_<%= group.key %>" style="cursor:pointer">
                    <label for="sec_<%= group.key %>" class="fw-semibold mb-0" style="cursor:pointer;color:var(--text);font-size:14px">
                      <%= group.label %>
                    </label>
                  </div>

                  <!-- Itens da secção -->
                  <div class="card border-0 ms-4" style="background:var(--surface2)">
                    <div class="card-body p-3">
                      <% group.items.forEach(function(item) { %>
                        <div class="d-flex align-items-center gap-3 py-1 perm-item" data-group="<%= group.key %>">
                          <span style="width:200px;font-size:13px"><%= item.label %></span>
                          <div class="form-check form-check-inline mb-0">
                            <input type="checkbox"
                              class="form-check-input perm-read"
                              name="perms[]"
                              value="<%= item.key %>.read"
                              id="r_<%= item.key.replace(/\./g,'_') %>"
                              data-write="w_<%= item.key.replace(/\./g,'_') %>"
                              <%= hasPerm(item.key + '.read') || hasPerm(item.key + '.write') ? 'checked' : '' %>>
                            <label class="form-check-label" for="r_<%= item.key.replace(/\./g,'_') %>" style="font-size:13px">Leitura</label>
                          </div>
                          <div class="form-check form-check-inline mb-0">
                            <input type="checkbox"
                              class="form-check-input perm-write"
                              name="perms[]"
                              value="<%= item.key %>.write"
                              id="w_<%= item.key.replace(/\./g,'_') %>"
                              data-read="r_<%= item.key.replace(/\./g,'_') %>"
                              <%= hasPerm(item.key + '.write') ? 'checked' : '' %>>
                            <label class="form-check-label" for="w_<%= item.key.replace(/\./g,'_') %>" style="font-size:13px">Escrita</label>
                          </div>
                        </div>
                      <% }) %>
                    </div>
                  </div>

                </div>
              <% }) %>
            </div>

          <% } %>

          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check-lg me-1"></i><%= isEdit ? 'Guardar' : 'Criar Função' %>
            </button>
            <a href="/admin/roles" class="btn btn-outline-secondary">Cancelar</a>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  // Escrita → marca Leitura automaticamente
  document.querySelectorAll('.perm-write').forEach(function(cb) {
    cb.addEventListener('change', function() {
      if (this.checked) {
        var readCb = document.getElementById(this.dataset.read);
        if (readCb) readCb.checked = true;
      }
    });
  });

  // Desmarcar Leitura → desmarca Escrita automaticamente
  document.querySelectorAll('.perm-read').forEach(function(cb) {
    cb.addEventListener('change', function() {
      if (!this.checked) {
        var writeCb = document.getElementById(this.dataset.write);
        if (writeCb) writeCb.checked = false;
      }
    });
  });

  // Checkbox de secção → marca/desmarca todos os itens do grupo
  document.querySelectorAll('.section-toggle').forEach(function(sec) {
    var group = sec.closest('.perm-group').dataset.group;

    // Estado inicial: indeterminate se misturado, checked se todos, unchecked se nenhum
    function syncSectionState() {
      var items = document.querySelectorAll('.perm-item[data-group="' + group + '"] input[type="checkbox"]');
      var total = items.length, checked = 0;
      items.forEach(function(i) { if (i.checked) checked++; });
      sec.indeterminate = checked > 0 && checked < total;
      sec.checked = checked === total;
    }

    sec.addEventListener('change', function() {
      var check = this.checked;
      document.querySelectorAll('.perm-item[data-group="' + group + '"] input[type="checkbox"]').forEach(function(cb) {
        cb.checked = check;
      });
    });

    document.querySelectorAll('.perm-item[data-group="' + group + '"] input[type="checkbox"]').forEach(function(cb) {
      cb.addEventListener('change', syncSectionState);
    });

    syncSectionState();
  });
})();
</script>

<%- include('../../partials/admin-layout-end') %>
