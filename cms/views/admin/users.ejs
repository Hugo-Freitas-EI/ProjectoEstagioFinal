<%- include('../partials/admin-layout', { pageTitle: 'Utilizadores', currentPage: 'users' }) %>

<div class="d-flex justify-content-end mb-3">
  <a href="/admin/users/new" class="btn btn-sm btn-primary">
    <i class="bi bi-person-plus me-1"></i> Novo Utilizador
  </a>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>Utilizador</th>
          <th>Email</th>
          <th>Função</th>
          <th>Criado em</th>
          <th class="text-end">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(u) { %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <div class="user-avatar"><%= u.username[0].toUpperCase() %></div>
                <div>
                  <div style="font-weight:500;font-size:14px"><%= u.username %></div>
                  <% if (u.authProvider) { %>
                    <span class="badge bg-info" style="font-size:9px"><%= u.authProvider %></span>
                  <% } %>
                </div>
              </div>
            </td>
            <td class="text-muted"><%= u.email %></td>
            <td>
              <span class="badge <%=
                u.role === 'admin'  ? 'bg-danger'  :
                u.role === 'editor' ? 'bg-primary'  : 'bg-secondary' %>">
                <%=
                  u.role === 'admin'  ? 'Admin'     :
                  u.role === 'editor' ? 'Editor'    : 'Subscritor' %>
              </span>
            </td>
            <td class="text-muted" style="font-size:13px">
              <%= new Date(u.createdAt).toLocaleDateString('pt-PT') %>
            </td>
            <td class="text-end">
              <div class="d-flex gap-1 justify-content-end">
                <a href="/admin/users/<%= u.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Editar">
                  <i class="bi bi-pencil"></i>
                </a>
                <% if (u.id !== currentUser.id) { %>
                  <form method="POST" action="/admin/users/<%= u.id %>/delete"
                    onsubmit="return confirm('Apagar utilizador <%= u.username %>?')" style="display:inline">
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Apagar">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/admin-layout-end') %>
