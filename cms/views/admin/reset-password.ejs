<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Redefinir password · NodeCMS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body>
<div class="auth-page">
  <div class="auth-card">
    <span class="auth-logo">NodeCMS</span>
    <p class="auth-sub">Nova password</p>

    <% if (error) { %>
      <div class="alert alert-danger mb-3"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success mb-3"><%= success %></div>
    <% } %>

    <% if (token) { %>
    <form method="POST" action="/admin/reset-password/<%= token %>">
      <div class="mb-3">
        <label class="form-label">Nova password</label>
        <div class="input-group">
          <input type="password" name="password" id="pw1" class="form-control"
            minlength="6" required autocomplete="new-password">
          <button type="button" class="btn btn-outline-secondary" onclick="toggleVis('pw1','ic1')" tabindex="-1">
            <i class="bi bi-eye" id="ic1"></i>
          </button>
        </div>
      </div>
      <div class="mb-4">
        <label class="form-label">Confirmar password</label>
        <div class="input-group">
          <input type="password" name="password_confirm" id="pw2" class="form-control"
            minlength="6" required autocomplete="new-password">
          <button type="button" class="btn btn-outline-secondary" onclick="toggleVis('pw2','ic2')" tabindex="-1">
            <i class="bi bi-eye" id="ic2"></i>
          </button>
        </div>
        <div id="mismatch" class="text-danger mt-1 d-none" style="font-size:13px">As passwords não coincidem.</div>
      </div>
      <button type="submit" class="btn btn-primary w-100" style="padding:10px">Redefinir password</button>
    </form>
    <% } %>

    <div class="text-center mt-3" style="font-size:13px">
      <a href="/admin/login" style="color:var(--accent2)">← Voltar ao login</a>
    </div>
  </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<script>
function toggleVis(fId, iId) {
  var f = document.getElementById(fId), i = document.getElementById(iId);
  f.type = f.type === 'password' ? 'text' : 'password';
  i.className = f.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
}
var pw1 = document.getElementById('pw1'), pw2 = document.getElementById('pw2');
if (pw1 && pw2) {
  function check() { document.getElementById('mismatch').classList.toggle('d-none', pw1.value === pw2.value); }
  pw1.addEventListener('input', check);
  pw2.addEventListener('input', check);
  document.querySelector('form').addEventListener('submit', function(e) {
    if (pw1.value !== pw2.value) { e.preventDefault(); document.getElementById('mismatch').classList.remove('d-none'); }
  });
}
</script>
</body>
</html>
