<%- include('../partials/admin-layout', { pageTitle: postType === 'page' ? 'Páginas' : 'Posts', currentPage: postType === 'page' ? 'pages' : 'posts' }) %>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px">

  <!-- Filtros de estado -->
  <div class="filter-tabs">
    <a href="?status=all&search=<%= search %>"
      class="btn btn-sm filter-tab <%= status === 'all' ? 'btn-primary' : 'btn-ghost' %>">
      Todos (<%= counts.all %>)
    </a>
    <a href="?status=publish&search=<%= search %>"
      class="btn btn-sm filter-tab <%= status === 'publish' ? 'btn-primary' : 'btn-ghost' %>">
      Publicados (<%= counts.publish %>)
    </a>
    <a href="?status=draft&search=<%= search %>"
      class="btn btn-sm filter-tab <%= status === 'draft' ? 'btn-primary' : 'btn-ghost' %>">
      Rascunhos (<%= counts.draft %>)
    </a>
  </div>

  <a href="/admin/<%= postType === 'page' ? 'pages' : 'posts' %>/new" class="btn btn-primary">
    + <%= postType === 'page' ? 'Nova Página' : 'Novo Post' %>
  </a>
</div>

<!-- Pesquisa via form GET normal -->
<form method="GET" action="/admin/<%= postType === 'page' ? 'pages' : 'posts' %>" style="margin-bottom:16px">
  <input type="hidden" name="status" value="<%= status %>">
  <div class="search-bar">
    <span class="search-icon">⌕</span>
    <input type="text" name="search" class="form-control"
      placeholder="Pesquisar <%= postType === 'page' ? 'páginas' : 'posts' %>..."
      value="<%= search %>">
  </div>
  <% if (search) { %>
    <div style="margin-top:6px">
      <span class="text-muted">A filtrar por "<%= search %>"</span>
      <a href="?status=<%= status %>" class="btn btn-ghost btn-sm" style="margin-left:8px">✕ Limpar</a>
    </div>
  <% } %>
</form>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Título</th>
        <th>Estado</th>
        <th>Data</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% if (posts.length === 0) { %>
        <tr>
          <td colspan="4" style="text-align:center;padding:48px;color:var(--text2)">
            <% if (search) { %>
              Nenhum resultado para "<%= search %>"
            <% } else { %>
              Sem <%= postType === 'page' ? 'páginas' : 'posts' %> ainda.
              <a href="/admin/<%= postType === 'page' ? 'pages' : 'posts' %>/new" style="color:var(--accent2)">Criar o primeiro</a>
            <% } %>
          </td>
        </tr>
      <% } %>
      <% posts.forEach(function(p) { %>
        <tr>
          <td>
            <a href="/admin/<%= postType === 'page' ? 'pages' : 'posts' %>/<%= p.ID %>/edit"
              style="font-weight:500;color:var(--accent2)">
              <%= p.post_title || '(sem título)' %>
            </a>
            <div class="text-muted" style="margin-top:2px">/<%= p.post_name %></div>
          </td>
          <td>
            <span class="badge badge-<%= p.post_status %>">
              <%= p.post_status === 'publish' ? 'Publicado' : 'Rascunho' %>
            </span>
          </td>
          <td class="text-muted">
            <%= new Date(p.post_date).toLocaleDateString('pt-PT') %>
          </td>
          <td style="white-space:nowrap">
            <a href="/admin/<%= postType === 'page' ? 'pages' : 'posts' %>/<%= p.ID %>/edit"
              class="btn btn-ghost btn-sm">Editar</a>
            <% if (p.post_status === 'publish') { %>
              <a href="/<%= postType === 'page' ? 'page' : 'post' %>/<%= p.post_name %>"
                target="_blank" class="btn btn-ghost btn-sm">↗</a>
            <% } %>
            <form method="POST"
              action="/admin/<%= postType === 'page' ? 'pages' : 'posts' %>/<%= p.ID %>/delete"
              style="display:inline"
              onsubmit="return confirm('Apagar permanentemente?')">
              <button type="submit" class="btn btn-danger btn-sm">Apagar</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Paginação -->
<% if (pagination.total > 1) { %>
  <div style="display:flex;justify-content:center;gap:6px;margin-top:20px">
    <% if (pagination.current > 1) { %>
      <a href="?page=<%= pagination.current - 1 %>&status=<%= status %>&search=<%= search %>"
        class="btn btn-ghost btn-sm">← Anterior</a>
    <% } %>
    <% for(var i = 1; i <= pagination.total; i++) { %>
      <a href="?page=<%= i %>&status=<%= status %>&search=<%= search %>"
        class="btn btn-sm <%= i === pagination.current ? 'btn-primary' : 'btn-ghost' %>"><%= i %></a>
    <% } %>
    <% if (pagination.current < pagination.total) { %>
      <a href="?page=<%= pagination.current + 1 %>&status=<%= status %>&search=<%= search %>"
        class="btn btn-ghost btn-sm">Próximo →</a>
    <% } %>
  </div>
<% } %>

<%- include('../partials/admin-layout-end') %>
