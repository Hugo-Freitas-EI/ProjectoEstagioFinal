<%- include('../partials/admin-layout', { pageTitle: pageTitle, currentPage: postType }) %>

  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div class="btn-group">
      <a href="/admin/cpt/<%= postType %>?status=all&search=<%= search %>"
        class="btn btn-sm <%= status === 'all' ? 'btn-primary' : 'btn-outline-secondary' %>">
        Todos <span class="ms-1" style="font-family:'DM Mono',monospace;font-size:10px">(<%= counts.all %>)</span>
      </a>
      <a href="/admin/cpt/<%= postType %>?status=publish&search=<%= search %>"
        class="btn btn-sm <%= status === 'publish' ? 'btn-primary' : 'btn-outline-secondary' %>">
        Publicados <span class="ms-1" style="font-family:'DM Mono',monospace;font-size:10px">(<%= counts.publish %>)</span>
      </a>
      <a href="/admin/cpt/<%= postType %>?status=draft&search=<%= search %>"
        class="btn btn-sm <%= status === 'draft' ? 'btn-primary' : 'btn-outline-secondary' %>">
        Rascunhos <span class="ms-1" style="font-family:'DM Mono',monospace;font-size:10px">(<%= counts.draft %>)</span>
      </a>
    </div>
    <a href="/admin/cpt/<%= postType %>/new" class="btn btn-sm btn-primary">
      <i class="bi bi-plus-lg me-1"></i> Novo <%= pageTitle.replace(/s$/, '' ) %>
    </a>
  </div>

  <form method="GET" action="/admin/cpt/<%= postType %>" class="mb-3">
    <input type="hidden" name="status" value="<%= status %>">
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-search"></i></span>
      <input type="text" name="search" class="form-control" placeholder="Pesquisar..." value="<%= search %>">
      <% if (search) { %>
        <a href="/admin/cpt/<%= postType %>?status=<%= status %>" class="btn btn-outline-secondary">
          <i class="bi bi-x-lg"></i>
        </a>
        <% } %>
    </div>
  </form>

  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th>Título</th>
            <th>Estado</th>
            <th>Autor</th>
            <th>Data</th>
            <th class="text-end">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (!posts.length) { %>
            <tr>
              <td colspan="5" style="text-align:center;padding:48px;color:var(--text2)">
                <i class="bi bi-inbox d-block mb-2" style="font-size:2rem;opacity:.4"></i>
                <% if (search) { %>
                  Nenhum resultado para "<%= search %>"
                    <% } else { %>
                      Sem conteúdo ainda.
                      <a href="/admin/cpt/<%= postType %>/new" style="color:var(--accent2)">Criar o primeiro</a>
                      <% } %>
              </td>
            </tr>
            <% } %>
              <% posts.forEach(function(p) { %>
                <tr>
                  <td>
                    <a href="/admin/cpt/<%= postType %>/<%= p.ID %>/edit" style="font-weight:500;color:var(--accent2)">
                      <%= p.post_title || '(sem título)' %>
                    </a>
                    <div class="text-muted" style="font-size:11px;font-family:'DM Mono',monospace;margin-top:2px">
                      /<%= p.post_name %>
                    </div>
                  </td>
                  <td>
                    <span class="badge <%= p.post_status === 'publish' ? 'bg-success' : 'bg-warning' %>">
                      <%= p.post_status==='publish' ? 'Publicado' : 'Rascunho' %>
                    </span>
                  </td>
                  <td class="text-muted" style="font-size:12px">
                    <%= p.username || '—' %>
                  </td>
                  <td class="text-muted" style="font-size:12px">
                    <%= new Date(p.post_date).toLocaleDateString('pt-PT') %>
                  </td>
                  <td class="text-end">
                    <div class="d-flex gap-1 justify-content-end">
                      <a href="/admin/cpt/<%= postType %>/<%= p.ID %>/edit" class="btn btn-sm btn-outline-secondary"><i
                          class="bi bi-pencil"></i></a>
                      <% if (p.post_status==='publish' ) { %>
                        <% var _prefix = postType === 'page' ? 'page' : (postType === 'post' ? 'post' : postType); %>
                        <a href="/<%= _prefix %>/<%= p.post_name %>" target="_blank"
                          class="btn btn-sm btn-outline-secondary">
                          <i class="bi bi-box-arrow-up-right"></i>
                        </a>
                        <% } %>
                          <form method="POST" action="/admin/cpt/<%= postType %>/<%= p.ID %>/delete"
                            onsubmit="return confirm('Apagar permanentemente?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                              <i class="bi bi-trash"></i>
                            </button>
                          </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <% if (pagination.total> 1) { %>
    <nav class="mt-3">
      <ul class="pagination pagination-sm justify-content-center mb-0">
        <li class="page-item <%= pagination.current === 1 ? 'disabled' : '' %>">
          <a class="page-link"
            href="/admin/cpt/<%= postType %>?page=<%= pagination.current-1 %>&status=<%= status %>&search=<%= search %>">
            <i class="bi bi-chevron-left"></i>
          </a>
        </li>
        <% for(var i=1; i <=pagination.total; i++) { %>
          <li class="page-item <%= i === pagination.current ? 'active' : '' %>">
            <a class="page-link"
              href="/admin/cpt/<%= postType %>?page=<%= i %>&status=<%= status %>&search=<%= search %>">
              <%= i %>
            </a>
          </li>
          <% } %>
            <li class="page-item <%= pagination.current === pagination.total ? 'disabled' : '' %>">
              <a class="page-link"
                href="/admin/cpt/<%= postType %>?page=<%= pagination.current+1 %>&status=<%= status %>&search=<%= search %>">
                <i class="bi bi-chevron-right"></i>
              </a>
            </li>
      </ul>
    </nav>
    <% } %>

      <%- include('../partials/admin-layout-end') %>