<%- include('../partials/admin-layout', { pageTitle: 'Media', currentPage: 'media' }) %>

<div class="d-flex align-items-center justify-content-between mb-3">
  <span class="text-muted"><%= files.length %> ficheiro(s)</span>
  <form method="POST" action="/admin/media/upload" enctype="multipart/form-data" id="upload-form">
    <input type="file" name="file" id="file-input" accept="image/*,application/pdf"
      style="display:none" onchange="this.form.submit()">
    <button type="button" class="btn btn-sm btn-primary"
      onclick="document.getElementById('file-input').click()">
      <i class="bi bi-upload me-1"></i> Carregar Ficheiro
    </button>
  </form>
</div>

<% if (files.length === 0) { %>
  <div class="card">
    <div class="card-body text-center py-5">
      <i class="bi bi-folder2-open d-block mb-3" style="font-size:3rem;opacity:.3"></i>
      <p class="text-muted mb-3">Nenhum ficheiro carregado ainda.</p>
      <button class="btn btn-sm btn-primary" onclick="document.getElementById('file-input').click()">
        Carregar primeiro ficheiro
      </button>
    </div>
  </div>
<% } else { %>
  <div class="row g-3">
    <% files.forEach(function(f) { %>
      <div class="col-6 col-sm-4 col-md-3 col-xl-2">
        <div class="card media-card">
          <% if (/\.(jpg|jpeg|png|gif|webp|svg)$/i.test(f.filename)) { %>
            <img src="<%= f.url %>" class="card-img-top"
              style="height:90px;object-fit:cover" loading="lazy" alt="<%= f.filename %>">
          <% } else { %>
            <div class="card-img-top d-flex align-items-center justify-content-center"
              style="height:90px;font-size:2rem;background:var(--bg)">📄</div>
          <% } %>
          <div class="media-name" title="<%= f.filename %>"><%= f.filename %></div>
          <div class="p-2 d-flex gap-1">
            <button class="btn btn-sm btn-outline-secondary flex-fill" 
              onclick="copyToClipboard('<%= f.url %>', this)"
              title="Copiar URL">
              <i class="bi bi-clipboard"></i>
            </button>
            <form method="POST" action="/admin/media/<%= f.filename %>/delete"
              onsubmit="return confirm('Apagar <%= f.filename %>?')" class="flex-fill">
              <button type="submit" class="btn btn-sm btn-outline-danger w-100" title="Apagar">
                <i class="bi bi-trash"></i>
              </button>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<script>
function copyToClipboard(text, btn) {
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(function() {
      var icon = btn.querySelector('i');
      if (icon) {
        icon.className = 'bi bi-check';
        setTimeout(function() {
          icon.className = 'bi bi-clipboard';
        }, 1500);
      }
    }).catch(function() {
      alert('URL: ' + text);
    });
  } else {
    alert('URL: ' + text);
  }
}
</script>

<%- include('../partials/admin-layout-end') %>
