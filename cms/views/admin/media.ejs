<%- include('../partials/admin-layout', { pageTitle: 'Media', currentPage: 'media' }) %>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
  <p class="text-muted"><%= files.length %> ficheiro(s) em /public/uploads/</p>

  <!-- Upload via form multipart normal -->
  <form method="POST" action="/admin/media/upload" enctype="multipart/form-data" id="upload-form">
    <input type="file" name="file" id="file-input" accept="image/*,application/pdf"
      style="display:none" onchange="document.getElementById('upload-form').submit()">
    <button type="button" class="btn btn-primary" onclick="document.getElementById('file-input').click()">
      + Carregar Ficheiro
    </button>
  </form>
</div>

<% if (files.length === 0) { %>
  <div class="empty-state">
    <div class="empty-icon">📁</div>
    <p>Nenhum ficheiro carregado ainda.</p>
    <button class="btn btn-primary" onclick="document.getElementById('file-input').click()">
      Carregar primeiro ficheiro
    </button>
  </div>
<% } else { %>
  <div class="media-grid">
    <% files.forEach(function(f) { %>
      <div class="media-item" onclick="openFileModal('<%= f.url %>','<%= f.filename %>','<%= (f.size/1024).toFixed(1) %>')">
        <% if (/\.(jpg|jpeg|png|gif|webp|svg)$/i.test(f.filename)) { %>
          <img class="media-thumb" src="<%= f.url %>" alt="<%= f.filename %>" loading="lazy">
        <% } else { %>
          <div class="media-thumb-icon">📄</div>
        <% } %>
        <div class="media-name"><%= f.filename %></div>
      </div>
    <% }) %>
  </div>
<% } %>

<!-- Modal de detalhes do ficheiro -->
<div class="modal-overlay" id="file-modal" style="display:none">
  <div class="modal" style="width:520px">
    <h3 id="modal-filename">Ficheiro</h3>
    <div id="modal-preview" style="text-align:center;margin-bottom:16px;min-height:60px"></div>

    <div class="form-group">
      <label class="form-label">URL</label>
      <div style="display:flex;gap:8px">
        <input type="text" id="modal-url" class="form-control" readonly>
        <button type="button" class="btn btn-ghost" onclick="copyUrl()">Copiar</button>
      </div>
      <div class="form-hint" id="modal-size"></div>
    </div>

    <div class="modal-footer">
      <!-- Apagar via form POST normal -->
      <form method="POST" id="delete-form" onsubmit="return confirm('Apagar este ficheiro?')">
        <button type="submit" class="btn btn-danger">Apagar</button>
      </form>
      <button type="button" class="btn btn-ghost" onclick="closeModal('file-modal')">Fechar</button>
    </div>
  </div>
</div>

<script>
function openFileModal(url, filename, sizeKb) {
  document.getElementById('modal-filename').textContent = filename;
  document.getElementById('modal-url').value = url;
  document.getElementById('modal-size').textContent = sizeKb + ' KB';
  document.getElementById('delete-form').action = '/admin/media/' + filename + '/delete';

  var prev = document.getElementById('modal-preview');
  if (/\.(jpg|jpeg|png|gif|webp|svg)$/i.test(filename)) {
    prev.innerHTML = '<img src="' + url + '" style="max-height:180px;border-radius:8px;max-width:100%">';
  } else {
    prev.innerHTML = '<span style="font-size:48px">📄</span>';
  }
  openModal('file-modal');
}

function copyUrl() {
  var input = document.getElementById('modal-url');
  navigator.clipboard.writeText(input.value).then(function() {
    var btn = event.target;
    btn.textContent = 'Copiado!';
    setTimeout(function() { btn.textContent = 'Copiar'; }, 1500);
  });
}
</script>

<%- include('../partials/admin-layout-end') %>
