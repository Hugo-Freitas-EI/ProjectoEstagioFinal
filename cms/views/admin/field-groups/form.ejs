<%- include('../../partials/admin-layout', { pageTitle: pageTitle, currentPage: 'field-groups' }) %>

<% if (error) { %><div class="alert alert-danger mb-3"><%= error %></div><% } %>

<div class="row g-3">

  <!-- Configuração do grupo -->
  <div class="col-lg-4">
    <div class="card mb-3">
      <div class="card-header">Grupo de Campos</div>
      <div class="card-body">
        <form method="POST" action="/admin/field-groups<%= isEdit ? '/' + group.id : '' %>" data-unsaved id="fg-form">
          <div class="mb-3">
            <label class="form-label">Nome do Grupo *</label>
            <input type="text" name="name" class="form-control"
              value="<%= group ? group.name : '' %>"
              placeholder="Ex: Detalhes do Produto" required>
          </div>
          <div class="mb-4">
            <label class="form-label">Post Types *</label>
            <% var selectedTypes = (group && group.post_types) ? group.post_types : []; %>
            <div class="border rounded" style="padding:6px 10px;max-height:180px;overflow-y:auto">
              <% if (typeof allPostTypes !== 'undefined' && allPostTypes.length) { %>
                <% allPostTypes.forEach(function(pt) { %>
                  <div class="form-check">
                    <input
                      class="form-check-input post-type-check"
                      type="checkbox"
                      name="post_type"
                      value="<%= pt.name %>"
                      id="pt_<%= pt.name %>"
                      <%= selectedTypes.includes(pt.name) ? 'checked' : '' %>
                    >
                    <label class="form-check-label" for="pt_<%= pt.name %>">
                      <%= pt.label %><% if (pt.system) { %> <span class="text-muted" style="font-size:11px">(sistema)</span><% } %>
                    </label>
                  </div>
                <% }) %>
              <% } %>
            </div>
            <div class="form-text">
              Não vês o tipo? <a href="/admin/post-types/new" target="_blank">Criar novo tipo de conteúdo</a>
            </div>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check-lg me-1"></i> <%= isEdit ? 'Guardar' : 'Criar Grupo' %>
            </button>
            <a href="/admin/field-groups" class="btn btn-outline-secondary">Cancelar</a>
          </div>
        </form>
      </div>
    </div>

    <% if (isEdit) { %>
      <div class="card">
        <div class="card-header" style="color:var(--danger)">Zona de Perigo</div>
        <div class="card-body">
          <p class="text-muted small mb-2">
            Apaga o grupo, todos os campos e todos os valores em post_meta.
          </p>
          <form method="POST" action="/admin/field-groups/<%= group.id %>/delete"
            onsubmit="return confirm('Apagar grupo, campos e todos os valores?')">
            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
              <i class="bi bi-trash me-1"></i> Apagar Grupo
            </button>
          </form>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Lista de campos (só em edição) -->
  <% if (isEdit) { %>
  <div class="col-lg-8">

    <!-- Tabela de campos existentes -->
    <div class="card mb-3">
      <div class="card-header d-flex align-items-center justify-content-between">
        <span style="font-family:'DM Serif Display',serif">Campos</span>
        <span class="text-muted" style="font-size:11px"><%= group.fields.length %> campo(s)</span>
      </div>

      <% if (!group.fields.length) { %>
        <div class="card-body text-center py-4 text-muted">
          <i class="bi bi-layout-text-sidebar d-block mb-2 opacity-50" style="font-size:1.8rem"></i>
          Ainda sem campos. Adiciona o primeiro abaixo.
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr><th>Label</th><th>Name</th><th>Tipo</th><th class="text-end">Ações</th></tr>
            </thead>
            <tbody>
              <% group.fields.forEach(function(f) { %>
                <tr id="row-<%= f.id %>">
                  <td style="font-weight:500"><%= f.label %></td>
                  <td style="font-family:'DM Mono',monospace;font-size:12px;color:var(--accent2)">
                    <%= f.name %>
                  </td>
                  <td><span class="badge bg-secondary"><%= f.type %></span></td>
                  <td class="text-end">
                    <div class="d-flex gap-1 justify-content-end">
                      <!-- Botão editar — expande painel inline -->
                      <button type="button" class="btn btn-sm btn-outline-secondary js-edit-field"
                        data-id="<%= f.id %>"
                        data-label="<%= f.label.replace(/'/g, '&#39;') %>"
                        data-name="<%= f.name %>"
                        data-type="<%= f.type %>">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <form method="POST"
                        action="/admin/field-groups/<%= group.id %>/fields/<%= f.id %>/delete"
                        onsubmit="return confirm('Apagar campo e todos os seus valores?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>

                <!-- Painel de edição inline (oculto por defeito) -->
                <tr id="edit-panel-<%= f.id %>" style="display:none">
                  <td colspan="4" style="background:var(--surface2);padding:16px 18px">
                    <form method="POST"
                      action="/admin/field-groups/<%= group.id %>/fields/<%= f.id %>">
                      <div class="row g-3 align-items-end">
                        <div class="col-sm-4">
                          <label class="form-label">Label</label>
                          <input type="text" name="label" id="edit-label-<%= f.id %>"
                            class="form-control form-control-sm" required>
                        </div>
                        <div class="col-sm-4">
                          <label class="form-label">Name</label>
                          <input type="text" name="name" id="edit-name-<%= f.id %>"
                            class="form-control form-control-sm">
                        </div>
                        <div class="col-sm-2">
                          <label class="form-label">Tipo</label>
                          <select name="type" id="edit-type-<%= f.id %>"
                            class="form-select form-select-sm">
                            <% fieldTypes.forEach(function(t) { %>
                              <option value="<%= t %>"><%= t %></option>
                            <% }) %>
                          </select>
                        </div>
                        <div class="col-sm-2 d-flex gap-1">
                          <button type="submit" class="btn btn-sm btn-primary flex-fill">
                            <i class="bi bi-check-lg"></i>
                          </button>
                          <button type="button" class="btn btn-sm btn-outline-secondary js-close-field"
                            data-id="<%= f.id %>">
                            <i class="bi bi-x-lg"></i>
                          </button>
                        </div>
                      </div>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Adicionar novo campo -->
    <div class="card">
      <div class="card-header">Adicionar Campo</div>
      <div class="card-body">
        <form method="POST" action="/admin/field-groups/<%= group.id %>/fields">
          <div class="row g-3 align-items-end">
            <div class="col-sm-5">
              <label class="form-label">Label *</label>
              <input type="text" name="label" class="form-control"
                placeholder="Ex: Preço" required>
            </div>
            <div class="col-sm-4">
              <label class="form-label">
                Name
                <span class="text-muted" style="text-transform:none;letter-spacing:0">(auto)</span>
              </label>
              <input type="text" name="name" class="form-control"
                placeholder="gerado do label">
            </div>
            <div class="col-sm-3">
              <label class="form-label">Tipo *</label>
              <select name="type" class="form-select" required>
                <% fieldTypes.forEach(function(t) { %>
                  <option value="<%= t %>"><%= t %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i> Adicionar Campo
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>

  </div><!-- col-lg-8 -->
  <% } %>

</div>

<script>
var activePanel = null;

function toggleEditPanel(id, label, name, type) {
  if (activePanel && activePanel !== id) {
    closeEditPanel(activePanel);
  }

  var panel = document.getElementById('edit-panel-' + id);
  if (!panel) return;

  if (panel.style.display !== 'none') {
    closeEditPanel(id);
  } else {
    document.getElementById('edit-label-' + id).value = label;
    document.getElementById('edit-name-'  + id).value = name;
    document.getElementById('edit-type-'  + id).value = type;
    panel.style.display = 'table-row';
    activePanel = id;
    document.getElementById('edit-label-' + id).focus();
  }
}

function closeEditPanel(id) {
  var panel = document.getElementById('edit-panel-' + id);
  if (panel) panel.style.display = 'none';
  if (activePanel === id) activePanel = null;
}

// Delegated click handlers (avoids EJS expressions inside onclick attributes)
document.addEventListener('click', function(e) {
  var editBtn  = e.target.closest('.js-edit-field');
  var closeBtn = e.target.closest('.js-close-field');

  if (editBtn) {
    var id    = editBtn.dataset.id;
    var label = editBtn.dataset.label;
    var name  = editBtn.dataset.name;
    var type  = editBtn.dataset.type;
    toggleEditPanel(id, label, name, type);
  }

  if (closeBtn) {
    closeEditPanel(closeBtn.dataset.id);
  }
});

// Fechar com Escape
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape' && activePanel) closeEditPanel(activePanel);
});

// Validar pelo menos um post type selecionado
document.getElementById('fg-form').addEventListener('submit', function(e) {
  var checked = this.querySelectorAll('.post-type-check:checked');
  if (!checked.length) {
    e.preventDefault();
    var wrap = this.querySelector('.border.rounded');
    wrap.style.borderColor = 'var(--bs-danger)';
    wrap.insertAdjacentHTML('afterend',
      '<div class="text-danger" style="font-size:.875em;margin-top:.25rem" id="pt-error">Seleciona pelo menos um post type.</div>'
    );
    setTimeout(function() {
      var err = document.getElementById('pt-error');
      if (err) err.remove();
      wrap.style.borderColor = '';
    }, 3000);
  }
});
</script>

<%- include('../../partials/admin-layout-end') %>
