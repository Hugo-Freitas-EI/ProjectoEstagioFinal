<%- include('../../partials/admin-layout', { pageTitle: pageTitle, currentPage: 'field-groups' }) %>

<% if (error) { %><div class="alert alert-danger mb-3"><%= error %></div><% } %>

<div class="row g-3">

  <!-- Configuração do grupo -->
  <div class="col-lg-4">
    <div class="card mb-3">
      <div class="card-header">Grupo de Campos</div>
      <div class="card-body">
        <form method="POST" action="/admin/field-groups<%= isEdit ? '/' + group.id : '' %>">
          <div class="mb-3">
            <label class="form-label">Nome do Grupo *</label>
            <input type="text" name="name" class="form-control"
              value="<%= group ? group.name : '' %>"
              placeholder="Ex: Detalhes do Produto" required>
          </div>
          <div class="mb-4">
            <label class="form-label">Post Type *</label>
            <input type="text" name="post_type" class="form-control"
              value="<%= group ? group.post_type : '' %>"
              placeholder="post, page, produto, evento..." required>
            <div class="form-text">Campos aparecem no editor deste post type</div>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check-lg me-1"></i> <%= isEdit ? 'Guardar' : 'Criar Grupo' %>
            </button>
            <a href="/admin/field-groups" class="btn btn-outline-secondary">Cancelar</a>
          </div>
        </form>
      </div>
    </div>

    <% if (isEdit) { %>
      <div class="card">
        <div class="card-header" style="color:var(--danger)">Zona de Perigo</div>
        <div class="card-body">
          <form method="POST" action="/admin/field-groups/<%= group.id %>/delete"
            onsubmit="return confirm('Apagar grupo e todos os campos? Os valores em post_meta também serão apagados.')">
            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
              <i class="bi bi-trash me-1"></i> Apagar Grupo
            </button>
          </form>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Lista de campos (só em edição) -->
  <% if (isEdit) { %>
  <div class="col-lg-8">

    <div class="card mb-3">
      <div class="card-header d-flex align-items-center justify-content-between">
        <span style="font-family:'DM Serif Display',serif">Campos</span>
        <span class="text-muted" style="font-size:11px"><%= group.fields.length %> campo(s)</span>
      </div>

      <% if (!group.fields.length) { %>
        <div class="card-body text-center py-4 text-muted">
          <i class="bi bi-layout-text-sidebar d-block mb-2 opacity-50" style="font-size:1.8rem"></i>
          Ainda sem campos. Adiciona o primeiro abaixo.
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead><tr>
              <th>Label</th><th>Name</th><th>Tipo</th><th>Opções</th><th class="text-end">Ações</th>
            </tr></thead>
            <tbody>
              <% group.fields.forEach(function(f) { %>
                <tr>
                  <td style="font-weight:500"><%= f.label %></td>
                  <td style="font-family:'DM Mono',monospace;font-size:12px;color:var(--accent2)"><%= f.name %></td>
                  <td><span class="badge bg-secondary"><%= f.type %></span></td>
                  <td class="text-muted" style="font-size:11px"><%= f.options || '—' %></td>
                  <td class="text-end">
                    <div class="d-flex gap-1 justify-content-end">
                      <button type="button" class="btn btn-sm btn-outline-secondary"
                        onclick="openEditField(<%= JSON.stringify(f) %>)"
                        data-bs-toggle="modal" data-bs-target="#editFieldModal">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <form method="POST"
                        action="/admin/field-groups/<%= group.id %>/fields/<%= f.id %>/delete"
                        onsubmit="return confirm('Apagar campo e todos os seus valores?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Adicionar campo -->
    <div class="card">
      <div class="card-header">Adicionar Campo</div>
      <div class="card-body">
        <form method="POST" action="/admin/field-groups/<%= group.id %>/fields">
          <div class="row g-3">
            <div class="col-sm-5">
              <label class="form-label">Label *</label>
              <input type="text" name="label" class="form-control" placeholder="Ex: Preço" required>
            </div>
            <div class="col-sm-4">
              <label class="form-label">Name</label>
              <input type="text" name="name" class="form-control" placeholder="gerado do label">
            </div>
            <div class="col-sm-3">
              <label class="form-label">Tipo *</label>
              <select name="type" class="form-select" required>
                <% fieldTypes.forEach(function(t) { %>
                  <option value="<%= t %>"><%= t %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-sm-8">
              <label class="form-label">Opções <span class="text-muted" style="text-transform:none;letter-spacing:0">(select: val1,val2,val3)</span></label>
              <input type="text" name="options" class="form-control" placeholder="Só para tipo select">
            </div>
            <div class="col-sm-2 d-flex align-items-end">
              <div class="form-check mb-1">
                <input type="checkbox" name="required" value="1" class="form-check-input" id="req-new">
                <label class="form-check-label form-text" for="req-new">Obrig.</label>
              </div>
            </div>
            <div class="col-sm-2 d-flex align-items-end">
              <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-plus-lg"></i> Adicionar
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>

  </div><!-- col-lg-8 -->
  <% } %>

</div>

<!-- Modal editar campo -->
<% if (isEdit) { %>
<div class="modal fade" id="editFieldModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Editar Campo</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" id="edit-field-form">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Label</label>
            <input type="text" name="label" id="ef-label" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Name</label>
            <input type="text" name="name" id="ef-name" class="form-control">
          </div>
          <div class="mb-3">
            <label class="form-label">Tipo</label>
            <select name="type" id="ef-type" class="form-select">
              <% fieldTypes.forEach(function(t) { %>
                <option value="<%= t %>"><%= t %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Opções</label>
            <input type="text" name="options" id="ef-options" class="form-control">
          </div>
          <div class="form-check">
            <input type="checkbox" name="required" value="1" id="ef-required" class="form-check-input">
            <label class="form-check-label" for="ef-required">Campo obrigatório</label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-sm btn-primary">Guardar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function openEditField(f) {
  document.getElementById('ef-label').value   = f.label;
  document.getElementById('ef-name').value    = f.name;
  document.getElementById('ef-type').value    = f.type;
  document.getElementById('ef-options').value = f.options || '';
  document.getElementById('ef-required').checked = !!f.required;
  document.getElementById('edit-field-form').action =
    '/admin/field-groups/<%= group.id %>/fields/' + f.id;
}
</script>
<% } %>

<%- include('../../partials/admin-layout-end') %>
