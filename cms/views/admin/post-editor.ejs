<%- include('../partials/admin-layout', { pageTitle: pageTitle, currentPage: currentPage }) %>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger mb-3"><%= error %></div>
<% } %>

<form method="POST" action="<%= formAction %>">
<div class="row g-3">

  <div class="col-lg-8">
    <div class="card mb-3">
      <div class="card-body">
        <input type="text" name="post_title" id="e-title" class="form-control border-0 p-0"
          placeholder="Título..."
          value="<%= post ? post.post_title : '' %>"
          oninput="autoSlug(this.value)"
          style="font-size:1.35rem;font-weight:600;box-shadow:none;font-family:'DM Serif Display',serif;color:var(--text)"
          required>
      </div>
    </div>

    <div class="card mb-3">
      <div class="card-header d-flex align-items-center gap-1 flex-wrap py-2">
        <button type="button" class="toolbar-btn" onclick="insertMd('**texto**')"><strong>B</strong></button>
        <button type="button" class="toolbar-btn" onclick="insertMd('*texto*')"><em>I</em></button>
        <button type="button" class="toolbar-btn" onclick="insertMd('# ')">H1</button>
        <button type="button" class="toolbar-btn" onclick="insertMd('## ')">H2</button>
        <button type="button" class="toolbar-btn" onclick="insertMd('### ')">H3</button>
        <div style="width:1px;height:18px;background:var(--border);margin:0 4px"></div>
        <button type="button" class="toolbar-btn" onclick="insertMd('[texto](url)')"><i class="bi bi-link-45deg"></i></button>
        <button type="button" class="toolbar-btn" onclick="insertMd('![alt](url)')"><i class="bi bi-image"></i></button>
        <button type="button" class="toolbar-btn" onclick="insertMd('\`código\`')"><i class="bi bi-code"></i></button>
        <button type="button" class="toolbar-btn" onclick="insertMd('> ')"><i class="bi bi-chat-quote"></i></button>
        <button type="button" class="toolbar-btn" onclick="insertMd('- ')"><i class="bi bi-list-ul"></i></button>
      </div>
      <div class="card-body p-0">
        <div class="editor-split">
          <textarea name="post_content" id="e-content"
            class="form-control"
            placeholder="Escreve em Markdown..."
            oninput="updatePreview()"><%= post ? post.post_content : '' %></textarea>
          <div>
            <div class="preview-label px-3 pt-3"><i class="bi bi-eye me-1"></i>Pré-visualização</div>
            <div class="preview-pane" id="e-preview"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">Excerto</div>
      <div class="card-body">
        <textarea name="post_excerpt" class="form-control border-0 p-0"
          placeholder="Resumo curto do post..."
          style="min-height:80px;resize:none;box-shadow:none"><%= post ? post.post_excerpt : '' %></textarea>
      </div>
    </div>
  </div>

  <div class="col-lg-4 d-flex flex-column gap-3">

    <div class="card">
      <div class="card-header">Publicação</div>
      <div class="card-body d-flex flex-column gap-2">
        <button type="submit" name="action" value="publish" class="btn btn-success">
          <i class="bi bi-check-lg me-1"></i> Publicar
        </button>
        <button type="submit" name="action" value="draft" class="btn btn-outline-secondary">
          <i class="bi bi-save me-1"></i> Guardar Rascunho
        </button>
        <% if (isEdit && post && post.post_status === 'publish') { %>
          <!--<a href="/<%= postType === 'page' ? 'page' : 'post' %>/<%= post.post_name %>"
            target="_blank" class="btn btn-outline-primary">
            <i class="bi bi-box-arrow-up-right me-1"></i> Ver no site
          </a>-->
          <a href=""
            target="" class="btn btn-outline-primary">
          <i class="bi bi-box-arrow-up-right me-1"></i> Ver no site
          </a>
        <% } %>
      </div>
    </div>

    <div class="card">
      <div class="card-header">Detalhes</div>
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label">Estado</label>
          <select name="post_status" class="form-select">
            <option value="draft" <%= !post || post.post_status === 'draft' ? 'selected' : '' %>>Rascunho</option>
            <option value="publish" <%= post && post.post_status === 'publish' ? 'selected' : '' %>>Publicado</option>
            <option value="private" <%= post && post.post_status === 'private' ? 'selected' : '' %>>Privado</option>
          </select>
        </div>
        <div>
          <label class="form-label">Data</label>
          <input type="date" name="post_date" class="form-control"
            value="<%= post ? new Date(post.post_date).toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>">
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">URL (Slug)</div>
      <div class="card-body">
        <input type="text" name="post_name" id="e-slug" class="form-control"
          value="<%= post ? post.post_name : '' %>" placeholder="url-do-post">
        <div class="form-text" id="slug-preview">/<%= post ? post.post_name : '' %></div>
      </div>
    </div>

    <% if (isEdit && post) { %>
      <div class="card">
        <div class="card-body">
          <div class="text-muted mb-2">ID: #<%= post.ID %></div>
          <form method="POST"
            action="/admin/<%= postType === 'page' ? 'pages' : 'posts' %>/<%= post.ID %>/delete"
            onsubmit="return confirm('Apagar permanentemente?')">
            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
              <i class="bi bi-trash me-1"></i> Apagar <%= postType === 'page' ? 'Página' : 'Post' %>
            </button>
          </form>
        </div>
      </div>
    <% } %>

  </div>
</div>
</form>

<%- include('../partials/admin-layout-end') %>
