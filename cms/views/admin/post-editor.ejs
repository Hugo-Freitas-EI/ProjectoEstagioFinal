<%- include('../partials/admin-layout', { pageTitle: pageTitle, currentPage: currentPage }) %>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error" style="margin-bottom:16px"><%= error %></div>
<% } %>

<form method="POST" action="<%= formAction %>">

<div class="editor-grid">

  <!-- COLUNA PRINCIPAL -->
  <div>
    <div class="form-group">
      <label class="form-label">Título</label>
      <input type="text" name="post_title" id="e-title" class="form-control"
        placeholder="Título..."
        value="<%= post ? post.post_title : '' %>"
        oninput="autoSlug(this.value)"
        style="font-size:20px;padding:12px 14px" required>
    </div>

    <div class="form-group">
      <label class="form-label">Conteúdo (Markdown)</label>
      <div class="editor-toolbar">
        <button type="button" class="toolbar-btn" onclick="insertMd('**texto**')"><strong>B</strong></button>
        <button type="button" class="toolbar-btn" onclick="insertMd('*texto*')"><em>I</em></button>
        <button type="button" class="toolbar-btn" onclick="insertMd('# ')">H1</button>
        <button type="button" class="toolbar-btn" onclick="insertMd('## ')">H2</button>
        <button type="button" class="toolbar-btn" onclick="insertMd('### ')">H3</button>
        <button type="button" class="toolbar-btn" onclick="insertMd('[texto](url)')">Link</button>
        <button type="button" class="toolbar-btn" onclick="insertMd('![alt](url)')">Img</button>
        <button type="button" class="toolbar-btn" onclick="insertMd('`código`')">Code</button>
        <button type="button" class="toolbar-btn" onclick="insertMd('> ')">Quote</button>
        <button type="button" class="toolbar-btn" onclick="insertMd('- ')">Lista</button>
      </div>
      <div class="editor-area">
        <textarea name="post_content" id="e-content" class="form-control"
          placeholder="Escreve em Markdown..."
          oninput="updatePreview()"><%= post ? post.post_content : '' %></textarea>
        <div>
          <div class="preview-label">Pré-visualização</div>
          <div class="preview-pane" id="e-preview"></div>
        </div>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Excerto (opcional)</label>
      <textarea name="post_excerpt" class="form-control" style="min-height:80px"
        placeholder="Resumo curto do post..."><%= post ? post.post_excerpt : '' %></textarea>
    </div>
  </div>

  <!-- COLUNA LATERAL -->
  <div class="editor-sidebar">

    <!-- Publicação -->
    <div class="card">
      <div class="form-label" style="margin-bottom:12px">Publicação</div>

      <div class="form-group">
        <label class="form-label">Estado</label>
        <select name="post_status" id="e-status" class="form-control">
          <option value="draft" <%= !post || post.post_status === 'draft' ? 'selected' : '' %>>Rascunho</option>
          <option value="publish" <%= post && post.post_status === 'publish' ? 'selected' : '' %>>Publicado</option>
          <option value="private" <%= post && post.post_status === 'private' ? 'selected' : '' %>>Privado</option>
        </select>
      </div>

      <div class="form-group" style="margin-bottom:0">
        <label class="form-label">Data</label>
        <input type="date" name="post_date" class="form-control"
          value="<%= post ? new Date(post.post_date).toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>">
      </div>
    </div>

    <!-- Slug -->
    <div class="card">
      <div class="form-label" style="margin-bottom:8px">URL (Slug)</div>
      <input type="text" name="post_name" id="e-slug" class="form-control"
        value="<%= post ? post.post_name : '' %>" placeholder="url-do-post">
      <div class="form-hint" id="slug-preview">/<%= post ? post.post_name : '' %></div>
    </div>

    <!-- Botões de ação -->
    <div class="card">
      <div style="display:flex;flex-direction:column;gap:8px">
        <button type="submit" name="action" value="draft" class="btn btn-ghost" style="justify-content:center">
          Guardar Rascunho
        </button>
        <button type="submit" name="action" value="publish" class="btn btn-success" style="justify-content:center">
          ✓ Publicar
        </button>
      </div>

      <% if (isEdit && post) { %>
        <div class="divider"></div>
        <div class="text-muted" style="margin-bottom:8px">ID: #<%= post.ID %></div>

        <% if (post.post_status === 'publish') { %>
          <a href="/<%= postType === 'page' ? 'page' : 'post' %>/<%= post.post_name %>"
            target="_blank" class="btn btn-ghost btn-sm"
            style="width:100%;justify-content:center;margin-bottom:8px">
            ↗ Ver no site
          </a>
        <% } %>

        <form method="POST"
          action="/admin/<%= postType === 'page' ? 'pages' : 'posts' %>/<%= post.ID %>/delete"
          onsubmit="return confirm('Apagar permanentemente?')">
          <button type="submit" class="btn btn-danger btn-sm"
            style="width:100%;justify-content:center">
            Apagar <%= postType === 'page' ? 'Página' : 'Post' %>
          </button>
        </form>
      <% } %>
    </div>

  </div>
</div>

</form>

<%- include('../partials/admin-layout-end') %>
