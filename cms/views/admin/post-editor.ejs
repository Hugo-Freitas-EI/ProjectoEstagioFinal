<%- include('../partials/admin-layout', { pageTitle: pageTitle, currentPage: currentPage }) %>

  <% if (typeof error !=='undefined' && error) { %>
    <div class="alert alert-danger mb-3">
      <%= error %>
    </div>
    <% } %>

      <form method="POST" action="<%= formAction %>">
        <div class="row g-3">

          <!-- ══════════════════════════════════════════════════════════════════════════ -->
          <!-- COLUNA PRINCIPAL (Editor de Conteúdo) -->
          <!-- ══════════════════════════════════════════════════════════════════════════ -->
          <div class="col-lg-8">

            <!-- Título -->
            <div class="card mb-3">
              <div class="card-body">
                <input type="text" name="post_title" id="e-title" class="form-control border-0 p-0"
                  placeholder="Título..." value="<%= post ? post.post_title : '' %>" oninput="autoSlug(this.value)"
                  style="font-size:1.35rem;font-weight:600;box-shadow:none;font-family:'DM Serif Display',serif;color:var(--text)"
                  required>
              </div>
            </div>

            <!--Markdon function-->
            <script>
              function toggleWrap(marker) {
                const textarea = document.getElementById("e-content");
                const start = textarea.selectionStart;
                const end = textarea.selectionEnd;
                const value = textarea.value;
                const selected = value.substring(start, end);

                if (!selected) return;

                const before = marker;
                const after = marker;

                if (
                  selected.startsWith(before) &&
                  selected.endsWith(after)
                ) {
                  // REMOVE
                  const unwrapped = selected.slice(
                    before.length,
                    selected.length - after.length
                  );

                  textarea.value =
                    value.substring(0, start) +
                    unwrapped +
                    value.substring(end);

                  textarea.setSelectionRange(start, start + unwrapped.length);
                } else {
                  // ADD
                  const wrapped = before + selected + after;

                  textarea.value =
                    value.substring(0, start) +
                    wrapped +
                    value.substring(end);

                  textarea.setSelectionRange(start, start + wrapped.length);
                }

                textarea.focus();
                updatePreview();
              }

              function toggleLinePrefix(prefix) {
                const textarea = document.getElementById("e-content");
                const start = textarea.selectionStart;
                const end = textarea.selectionEnd;
                const value = textarea.value;

                const beforeSelection = value.substring(0, start);
                const selection = value.substring(start, end);
                const afterSelection = value.substring(end);

                const lines = selection.split("\n");

                const allHavePrefix = lines.every(line =>
                  line.startsWith(prefix)
                );

                const newLines = lines.map(line => {
                  if (allHavePrefix) {
                    // REMOVE prefix
                    return line.startsWith(prefix)
                      ? line.slice(prefix.length)
                      : line;
                  } else {
                    // ADD prefix
                    return prefix + line;
                  }
                });

                const newSelection = newLines.join("\n");

                textarea.value =
                  beforeSelection +
                  newSelection +
                  afterSelection;

                textarea.setSelectionRange(
                  start,
                  start + newSelection.length
                );

                textarea.focus();
                updatePreview();
              }

              document.addEventListener("DOMContentLoaded", function () {
                const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
                tooltipTriggerList.forEach(function (tooltipTriggerEl) {
                  new bootstrap.Tooltip(tooltipTriggerEl);
                });
              });

            </script>
            <!-- Editor Markdown -->
            <div class="card mb-3">
              <div class="card-header d-flex align-items-center gap-1 flex-wrap py-2">
                <button type="button" class="toolbar-btn" onclick="toggleWrap('**')" data-bs-toggle="tooltip"
                  title="Negrito (Ctrl+B)">
                  <strong>B</strong>
                </button>
                <button type="button" class="toolbar-btn" onclick="toggleWrap('*')" data-bs-toggle="tooltip"
                  title="Itálico (Ctrl+I)">
                  <em>I</em>
                </button>
                <button type="button" class="toolbar-btn" onclick="toggleLinePrefix('# ')" data-bs-toggle="tooltip"
                  title="Título H1">
                  H1
                </button>
                <button type="button" class="toolbar-btn" onclick="toggleLinePrefix('## ')" data-bs-toggle="tooltip"
                  title="Título H2">
                  H2
                </button>
                <button type="button" class="toolbar-btn" onclick="toggleLinePrefix('### ')" data-bs-toggle="tooltip"
                  title="Título H3">
                  H3
                </button>
                <button type="button" class="toolbar-btn" onclick="toggleLinePrefix('- ')" data-bs-toggle="tooltip"
                  title="Lista">
                  <i class="bi bi-list-ul"></i>
                </button>
                <div style="width:1px;height:18px;background:var(--border);margin:0 4px"></div>
                <button type="button" class="toolbar-btn" onclick="insertMd('[texto](url)')" data-bs-toggle="tooltip"
                  title="Inserir Link (Ctrl+K)">
                  <i class="bi bi-link-45deg"></i>
                </button>

                <button type="button" class="toolbar-btn" onclick="insertMd('![alt](url)')" data-bs-toggle="tooltip"
                  title="Inserir Imagem">
                  <i class="bi bi-image"></i>
                </button>
                <button type="button" class="toolbar-btn" onclick="toggleWrap('`')" data-bs-toggle="tooltip"
                  title="Código inline">
                  <i class="bi bi-code"></i>
                </button>
                <button type="button" class="toolbar-btn" onclick="toggleLinePrefix('> ')" data-bs-toggle="tooltip"
                  title="Citação">
                  <i class="bi bi-chat-quote"></i>
                </button>

                <button type="button" class="toolbar-btn" onclick="document.execCommand('undo')"
                  data-bs-toggle="tooltip" title="Anular">
                  <i class="bi bi-arrow-counterclockwise"></i>
                </button>

                <button type="button" class="toolbar-btn" onclick="document.execCommand('redo')"
                  data-bs-toggle="tooltip" title="Refazer">
                  <i class="bi bi-arrow-clockwise"></i>
                </button>

              </div>
              <div class="card-body p-0">
                <div class="editor-split">
                  <textarea name="post_content" id="e-content" class="form-control" placeholder="Escreve em Markdown..."
                    oninput="updatePreview()"><%= post ? post.post_content : '' %></textarea>
                  <div>
                    <div class="preview-label px-3 pt-3"><i class="bi bi-eye me-1"></i>Pré-visualização</div>
                    <div class="preview-pane" id="e-preview"></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Excerto -->
            <div class="card mb-3">
              <div class="card-header">Excerto</div>
              <div class="card-body">
                <textarea name="post_excerpt" class="form-control border-0 p-0" placeholder="Resumo curto do post..."
                  style="min-height:70px;resize:none;box-shadow:none"><%= post ? (post.post_excerpt || '') : '' %></textarea>
              </div>
            </div>

