<%- include('../partials/admin-layout', { pageTitle: pageTitle, currentPage: currentPage }) %>

  <% if (typeof error !=='undefined' && error) { %>
    <div class="alert alert-danger mb-3">
      <%= error %>
    </div>
    <% } %>

      <form method="POST" action="<%= formAction %>" data-unsaved>
        <div class="row g-3">

          <div class="col-lg-8">

            <!-- Título -->
            <div class="card mb-3">
              <div class="card-body">
                <input type="text" name="post_title" id="e-title" class="form-control border-0 p-0"
                  placeholder="Título..." value="<%= post ? post.post_title : '' %>" oninput="autoSlug(this.value)"
                  style="font-size:1.35rem;font-weight:600;box-shadow:none;font-family:'DM Serif Display',serif;color:var(--text)"
                  required>
              </div>
            </div>

            <script>
              function aplicarFormato(comando, valor = null) {
                document.execCommand(comando, false, valor);
                document.getElementById('editor-visual').focus();
                sincronizarEditor();
              }

              function inserirLink() {
                const url = prompt("Insira o URL do link:");
                if (url) {
                  aplicarFormato('createLink', url);
                }
              }

              document.addEventListener("DOMContentLoaded", function () {
                const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
                tooltipTriggerList.forEach(function (tooltipTriggerEl) {
                  new bootstrap.Tooltip(tooltipTriggerEl);
                });

                // Sincronizar qualquer alteração no visual com a textarea invisível
                document.getElementById('editor-visual').addEventListener('input', sincronizarEditor);
              });

              function sincronizarEditor() {
                const html = document.getElementById('editor-visual').innerHTML;
                document.getElementById('e-content').value = (html || '').trim();
              }

              // Lógica da Pré-visualização
              let isPreviewMode = false;
              function togglePreview() {
                const editor = document.getElementById('editor-visual');
                const preview = document.getElementById('preview-visual');
                const btn = document.getElementById('btn-preview');
                const toolbars = document.querySelectorAll('.toolbar-btn');

                isPreviewMode = !isPreviewMode;

                if (isPreviewMode) {
                  // Copia o HTML atual para a janela de pré-visualização
                  preview.innerHTML = editor.innerHTML;

                  // Esconde o editor e mostra a pré-visualização
                  editor.classList.add('d-none');
                  preview.classList.remove('d-none');

                  // Desativa os botões de formatação
                  toolbars.forEach(b => b.classList.add('disabled'));

                  // Muda o aspeto do botão
                  btn.innerHTML = '<i class="bi bi-pencil me-1"></i> Voltar ao Editor';
                  btn.classList.replace('btn-outline-secondary', 'btn-primary');
                } else {
                  // Mostra o editor e esconde a pré-visualização
                  editor.classList.remove('d-none');
                  preview.classList.add('d-none');

                  // Reativa os botões de formatação
                  toolbars.forEach(b => b.classList.remove('disabled'));

                  // Muda o aspeto do botão de volta
                  btn.innerHTML = '<i class="bi bi-eye me-1"></i> Pré-visualização';
                  btn.classList.replace('btn-primary', 'btn-outline-secondary');
                  editor.focus();
                }
              }
            </script>

            <!-- Editor WYSIWYG -->
            <div class="card mb-3">
              <div class="card-header d-flex align-items-center gap-1 flex-wrap py-2">
                <button type="button" class="toolbar-btn" onclick="aplicarFormato('bold')" data-bs-toggle="tooltip"
                  title="Negrito (Ctrl+B)">
                  <strong>B</strong>
                </button>
                <button type="button" class="toolbar-btn" onclick="aplicarFormato('italic')" data-bs-toggle="tooltip"
                  title="Itálico (Ctrl+I)">
                  <em>I</em>
                </button>

                <div style="width:1px;height:18px;background:var(--border);margin:0 4px"></div>

                <button type="button" class="toolbar-btn" onclick="aplicarFormato('formatBlock', 'H1')"
                  data-bs-toggle="tooltip" title="Título H1">
                  H1
                </button>
                <button type="button" class="toolbar-btn" onclick="aplicarFormato('formatBlock', 'H2')"
                  data-bs-toggle="tooltip" title="Título H2">
                  H2
                </button>
                <button type="button" class="toolbar-btn" onclick="aplicarFormato('formatBlock', 'H3')"
                  data-bs-toggle="tooltip" title="Título H3">
                  H3
                </button>

                <div style="width:1px;height:18px;background:var(--border);margin:0 4px"></div>

                <button type="button" class="toolbar-btn" onclick="aplicarFormato('insertUnorderedList')"
                  data-bs-toggle="tooltip" title="Lista">
                  <i class="bi bi-list-ul"></i>
                </button>
                <button type="button" class="toolbar-btn" onclick="inserirLink()" data-bs-toggle="tooltip"
                  title="Inserir Link">
                  <i class="bi bi-link-45deg"></i>
                </button>
                <button type="button" class="toolbar-btn" onclick="abrirBibliotecaMedia()" data-bs-toggle="tooltip"
                  title="Inserir Imagem da Biblioteca">
                  <i class="bi bi-image"></i>
                </button>

                <div style="width:1px;height:18px;background:var(--border);margin:0 4px"></div>

                <button type="button" class="toolbar-btn" onclick="aplicarFormato('formatBlock', 'PRE')"
                  data-bs-toggle="tooltip" title="Código">
                  <i class="bi bi-code"></i>
                </button>
                <button type="button" class="toolbar-btn" onclick="aplicarFormato('formatBlock', 'BLOCKQUOTE')"
                  data-bs-toggle="tooltip" title="Citação">
                  <i class="bi bi-chat-quote"></i>
                </button>

                <div style="width:1px;height:18px;background:var(--border);margin:0 4px"></div>

                <button type="button" class="toolbar-btn" onclick="aplicarFormato('undo')" data-bs-toggle="tooltip"
                  title="Anular">
                  <i class="bi bi-arrow-counterclockwise"></i>
                </button>
                <button type="button" class="toolbar-btn" onclick="aplicarFormato('redo')" data-bs-toggle="tooltip"
                  title="Refazer">
                  <i class="bi bi-arrow-clockwise"></i>
                </button>

                <div style="width:1px;height:18px;background:var(--border);margin:0 4px"></div>

                <button type="button" id="btn-preview" class="btn btn-sm btn-outline-secondary ms-2"
                  onclick="togglePreview()" data-bs-toggle="tooltip" title="Alternar Pré-visualização">
                  <i class="bi bi-eye me-1"></i> Pré-visualização
                </button>
              </div>

              <div class="card-body p-0 position-relative">
                <textarea name="post_content" id="e-content"
                  class="d-none"><%= post ? post.post_content : '' %></textarea>

                <div id="image-toolbar" class="d-none shadow-sm"
                  style="background-color: var(--bg-card, #1e1e2d); border-color: var(--border, #2b2b40);">
                  <button type="button" class="toolbar-btn" onclick="formatarImagem('esquerda')"
                    title="Alinhar à Esquerda">
                    <i class="bi bi-text-left"></i>
                  </button>
                  <button type="button" class="toolbar-btn" onclick="formatarImagem('centro')" title="Centrar">
                    <i class="bi bi-text-center"></i>
                  </button>
                  <button type="button" class="toolbar-btn" onclick="formatarImagem('direita')"
                    title="Alinhar à Direita">
                    <i class="bi bi-text-right"></i>
                  </button>
                  <button type="button" class="toolbar-btn" onclick="formatarImagem('nenhum')" title="Sem Alinhamento">
                    <i class="bi bi-x-circle"></i>
                  </button>

                  <div style="width:1px;height:18px;background:var(--border);margin:0 4px"></div>

                  <button type="button" class="toolbar-btn" onclick="formatarImagem('remover')" title="Remover Imagem">
                    <i class="bi bi-trash text-danger"></i>
                  </button>
                </div>

                <div id="editor-visual" contenteditable="true" class="form-control border-0"
                  style="min-height: 400px; max-height: 600px; overflow-y: auto; padding: 1.5rem; border-radius: 0 0 0.375rem 0.375rem;">
                  <%- post ? post.post_content : '' %>
                </div>

                <div id="preview-visual" class="d-none"
                  style="min-height: 400px; max-height: 600px; overflow-y: auto; padding: 1.5rem; background-color: rgba(0,0,0,0.02); border-radius: 0 0 0.375rem 0.375rem;">
                </div>
              </div>
            </div>

            <!-- Excerto -->
            <div class="card mb-3">
              <div class="card-header d-flex justify-content-between align-items-center">
                <span>Excerto</span>
                <i class="bi bi-chevron-up text-muted card-toggle" style="cursor: pointer;"></i>
              </div>
              <div class="card-body">
                <textarea name="post_excerpt" class="form-control border-0 p-0" placeholder="  Resumo curto do post..."
                  style="min-height:70px;resize:none;box-shadow:none"><%= post ? (post.post_excerpt || '') : '' %></textarea>
              </div>
            </div>

            <% if (typeof revisions !=='undefined' && revisions.length> 0) { %>
              <div class="card mb-3" id="revisions-box">
                <div class="card-header d-flex justify-content-between align-items-center">
                  <span class="fw-semibold">Revisões</span>
                  <div>
                    <i class="bi bi-chevron-up text-muted" style="cursor: pointer;"></i>
                  </div>
                </div>
                <div class="card-body p-0">
                  <ul class="list-group list-group-flush">
                    <% revisions.forEach(function(rev) { %>
                      <li class="list-group-item d-flex align-items-center gap-3 py-3">
                        <div
                          style="width: 40px; height: 40px; background-color: #e2e4e7; border-radius: 4px; display: flex; align-items: center; justify-content: center;">
                          <i class="bi bi-person-fill" style="color: #fff; font-size: 24px;"></i>
                        </div>

                        <div style="font-size: 14px;">
                          <a href="#" class="text-decoration-none fw-medium">
                            <%= rev.author_name || 'Autor' %>
                          </a>,
                          <span class="text-muted">
                            <%= rev.timeAgo %>
                          </span>
                          <a href="#" class="text-decoration-none text-muted">
                            (<%= rev.exactDateFormatted %>)
                          </a>
                          <% if (rev.isAutoSave) { %>
                            <span class="text-danger ms-1">[Cópia automática]</span>
                            <% } %>
                        </div>
                      </li>
                      <% }) %>
                  </ul>
                </div>
              </div>
              <% } %>

                <!-- ══════════════════════════════════════════════════════════════════════════ -->
                <!-- CUSTOM FIELDS DINÂMICOS -->
                <!-- ══════════════════════════════════════════════════════════════════════════ -->
                <% if (typeof fieldGroups !=='undefined' && fieldGroups && fieldGroups.length) { %>
                  <% fieldGroups.forEach(function(group) { %>
                    <div class="card mb-3">
                      <div class="card-header d-flex align-items-center gap-2">
                        <i class="bi bi-sliders" style="color:var(--accent2)"></i>
                        <span style="font-family:'DM Serif Display',serif">
                          <%= group.name %>
                        </span>
                      </div>
                      <div class="card-body">
                        <div class="row g-3">
                          <% if (group.fields && group.fields.length) { %>
                            <% group.fields.forEach(function(field) { %>
                              <div class="<%= field.type === 'textarea' ? 'col-12' : 'col-sm-6' %>">
                                <label class="form-label">
                                  <%= field.label %>
                                    <span
                                      style="font-family:'DM Mono',monospace;font-size:9px;color:var(--text2);text-transform:lowercase;letter-spacing:0;margin-left:4px">
                                      <%= field.type %>
                                    </span>
                                </label>

                                <% if (field.type==='textarea' ) { %>
                                  <textarea name="meta_<%= field.id %>" class="form-control"
                                    style="min-height:100px"><%= field.value || '' %></textarea>

                                  <% } else if (field.type==='checkbox' ) { %>
                                    <div class="form-check mt-1">
                                      <input type="hidden" name="meta_<%= field.id %>" value="0">
                                      <input type="checkbox" name="meta_<%= field.id %>" value="1"
                                        class="form-check-input" id="field_<%= field.id %>" <%=field.value=='1'
                                        ? 'checked' : '' %>>
                                      <label class="form-check-label" for="field_<%= field.id %>">Ativo</label>
                                    </div>

                                    <% } else if (field.type==='select' && field.options) { %>
                                      <select name="meta_<%= field.id %>" class="form-select">
                                        <option value="">Selecione...</option>
                                        <% field.options.split(',').forEach(function(opt) { %>
                                          <option value="<%= opt.trim() %>" <%=field.value===opt.trim() ? 'selected'
                                            : '' %>><%= opt.trim() %>
                                          </option>
                                          <% }) %>
                                      </select>

                                      <% } else { %>
                                        <input
                                          type="<%= ['url', 'image', 'file'].includes(field.type) ? 'url' : field.type %>"
                                          name="meta_<%= field.id %>" class="form-control"
                                          value="<%= field.value || '' %>"
                                          placeholder="<%= ['url', 'image', 'file'].includes(field.type) ? 'https://...' : '' %>">
                                        <% } %>
                              </div>
                              <% }) %>
                                <% } else { %>
                                  <div class="col-12 text-muted text-center py-3">
                                    <small>Este grupo não tem campos definidos.</small>
                                  </div>
                                  <% } %>
                        </div>
                      </div>
                    </div>
                    <% }) %>
                      <% } %>

          </div>

          <!-- COLUNA LATERAL -->
          <div class="col-lg-4 d-flex flex-column gap-3">

            <!-- Publicação -->
            <div class="card">
              <div class="card-header d-flex justify-content-between align-items-center">
                <span>Publicação</span>
                <i class="bi bi-chevron-up text-muted card-toggle" style="cursor: pointer;"></i>
              </div>
              <div class="card-body d-flex flex-column gap-2">
                <button type="submit" name="action" value="publish" class="btn btn-success">
                  <i class="bi bi-check-lg me-1"></i> Publicar
                </button>
                <button type="submit" name="action" value="draft" class="btn btn-outline-secondary">
                  <i class="bi bi-save me-1"></i> Guardar Rascunho
                </button>
                <% if (typeof revisions !=='undefined' && revisions.length> 0) { %>
                  <div class="mt-3 pt-3 border-top d-flex align-items-center gap-2" style="font-size: 14px;">
                    <i class="bi bi-clock-history text-muted"></i>
                    <span class="text-muted">Revisões: <b>
                        <%= revisions.length %>
                      </b></span>
                    <% const section=(post && post.post_type==='page' ) ? 'pages' : 'posts' ; %>

                      <a href="/admin/<%= section %>/<%= post.ID %>/revisions/compare"
                        class="btn btn-sm btn-outline-primary">
                        Ver todas
                      </a>
                  </div>
                  <% } %>

                    <% if (typeof isEdit !=='undefined' && isEdit && post && post.post_status==='publish' ) { %>
                      <%
                        var _prefix = postType === 'page' ? 'page' : (postType === 'post' ? 'post' : postType);
                      %>
                      <a href="/<%= _prefix %>/<%= post.post_name %>" target="_blank" class="btn btn-outline-primary">
                        <i class="bi bi-box-arrow-up-right me-1"></i> Ver no site
                      </a>
                      <% } %>
              </div>
            </div>

            <!-- Detalhes -->
            <div class="card">
              <div class="card-header d-flex justify-content-between align-items-center">
                <span>Detalhes</span>
                <i class="bi bi-chevron-up text-muted card-toggle" style="cursor: pointer;"></i>
              </div>
              <div class="card-body">
                <div class="mb-3">
                  <label class="form-label">Estado</label>
                  <select name="post_status" class="form-select">
                    <option value="draft" <%=!post || post.post_status==='draft' ? 'selected' : '' %>>Rascunho</option>
                    <option value="publish" <%=post && post.post_status==='publish' ? 'selected' : '' %>>Publicado
                    </option>
                    <option value="private" <%=post && post.post_status==='private' ? 'selected' : '' %>>Privado
                    </option>
                  </select>
                </div>
                <div>
                  <label class="form-label">Data</label>
                  <input type="date" name="post_date" class="form-control"
                    value="<%= post && post.post_date ? new Date(post.post_date).toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>">
                </div>
              </div>
            </div>

            <!-- URL Slug -->
            <div class="card">
              <div class="card-header d-flex justify-content-between align-items-center">
                <span>URL (Slug)</span>
                <i class="bi bi-chevron-up text-muted card-toggle" style="cursor: pointer;"></i>
              </div>
              <div class="card-body">
                <input type="text" name="post_name" id="e-slug" class="form-control"
                  value="<%= post ? post.post_name : '' %>" placeholder="url-do-post">
                <div class="form-text" id="slug-preview">/<%= post ? post.post_name : '' %>
                </div>
              </div>
            </div>

            <!-- ══════════════════════════════════════════════════════════════════════════ -->
            <!-- TAXONOMIAS (Termos/Categorias) -->
            <!-- ══════════════════════════════════════════════════════════════════════════ -->
            <%
              if (typeof allTerms !== 'undefined' && allTerms && allTerms.length) {
                var termsByCategory = {};
                allTerms.forEach(function(t) {
                  var catName = t.category_name || 'Sem Categoria';
                  if (!termsByCategory[catName]) { termsByCategory[catName] = []; }
                  termsByCategory[catName].push(t);
                });
              }
            %>
            <% if (typeof allTerms !== 'undefined' && allTerms && allTerms.length) { %>
                <div class="card">
                  <div class="card-header d-flex align-items-center justify-content-between">
                    <span>Taxonomias</span>
                    <a href="/admin/terms/new" target="_blank" class="btn btn-sm btn-outline-secondary"
                      style="padding:2px 8px;font-size:10px" title="Adicionar novo termo">
                      <i class="bi bi-plus-lg"></i>
                    </a>
                  </div>
                  <div class="card-body">
                    <% Object.entries(termsByCategory).forEach(function([catName, terms]) { %>
                      <div class="mb-3">
                        <div class="form-label" style="color:var(--accent2);font-size:13px;font-weight:500">
                          <%= catName %>
                        </div>
                        <div class="d-flex flex-column gap-1">
                          <% terms.forEach(function(t) { %>
                            <div class="form-check">
                              <input type="checkbox" name="term_ids[]" value="<%= t.id %>" class="form-check-input"
                                id="term_<%= t.id %>" <%= (typeof selectedTermIds !== 'undefined' && selectedTermIds &&
                                selectedTermIds.includes(t.id)) ? 'checked' : '' %>>
                              <label class="form-check-label" for="term_<%= t.id %>" style="font-size:13px">
                                <%= t.name %>
                              </label>
                            </div>
                          <% }) %>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
            <% } %>

                  <!-- Apagar Post -->
                  <% if (typeof isEdit !=='undefined' && isEdit && post) { %>
                    <% var itemType=typeof postType !=='undefined' && postType==='page' ? 'página' : 'post' ; var
                      confirmMsg='Apagar permanentemente esta ' + itemType + '? Esta ação não pode ser revertida.' ; %>
                      <div class="card">
                        <div class="card-body">
                          <h5 class="card-title text-danger">Apagar <%= itemType %>
                          </h5>
                          <form method="POST" action="/admin/posts/<%= post.ID %>/delete"
                            onsubmit="return confirm('<%= confirmMsg %>')">
                            <button type="submit" class="btn btn-danger mt-2">
                              <i class="bi bi-trash me-1"></i> Apagar <%= itemType %>
                            </button>
                          </form>
                        </div>
                      </div>
                      <% } %>

          </div>
        </div>
      </form>

      <!-- Offcanvas - Biblioteca de Media -->
      <div class="offcanvas offcanvas-end" tabindex="-1" id="bibliotecaMediaOffcanvas"
        style="width:600px;background:var(--surface);border-left:1px solid var(--border)">
        <div class="offcanvas-header border-bottom"
          style="background:var(--surface);border-color:var(--border) !important">
          <div class="d-flex align-items-center gap-2">
            <button id="media-back-btn" type="button" class="btn btn-sm btn-outline-secondary d-none">
              <i class="bi bi-arrow-left"></i>
            </button>
            <h5 class="offcanvas-title fw-bold mb-0" style="color:var(--text)">Selecionar Imagem</h5>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body p-3" style="background:var(--bg)">

          <div id="media-loading" class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
              <span class="visually-hidden">A carregar...</span>
            </div>
          </div>

          <div id="media-grid" class="row g-3 d-none"></div>

          <div id="media-empty" class="text-center py-5 d-none">
            <i class="bi bi-image" style="font-size:3rem;color:var(--text2)"></i>
            <p class="mt-3" style="color:var(--text2)">Nenhum conteúdo disponível.</p>
            <a href="/admin/media" class="btn btn-sm btn-primary" target="_blank">
              <i class="bi bi-upload me-1"></i> Carregar Imagens
            </a>
          </div>

        </div>
      </div>

      <script>
        // Estado da navegação de pastas
        var mediaFolderStack = []; // pilha de IDs de pasta

        // Abrir biblioteca de media
        function abrirBibliotecaMedia() {
          mediaFolderStack = [];
          document.getElementById('media-back-btn').classList.add('d-none');
          var offcanvas = new bootstrap.Offcanvas(document.getElementById('bibliotecaMediaOffcanvas'));
          offcanvas.show();
          carregarMediaPasta(null);
        }

        document.getElementById('media-back-btn').addEventListener('click', function () {
          mediaFolderStack.pop();
          var parentId = mediaFolderStack.length ? mediaFolderStack[mediaFolderStack.length - 1] : null;
          if (!mediaFolderStack.length) this.classList.add('d-none');
          carregarMediaPasta(parentId);
        });

        // Carregar conteúdo de uma pasta via AJAX
        function carregarMediaPasta(folderId) {
          var loadingEl = document.getElementById('media-loading');
          var gridEl = document.getElementById('media-grid');
          var emptyEl = document.getElementById('media-empty');

          loadingEl.classList.remove('d-none');
          gridEl.classList.add('d-none');
          emptyEl.classList.add('d-none');

          var url = '/admin/media/api/list' + (folderId ? '?folder=' + folderId : '');

          fetch(url)
            .then(function (r) { return r.json(); })
            .then(function (data) {
              loadingEl.classList.add('d-none');

              var items = data.files || [];
              if (items.length === 0) {
                emptyEl.classList.remove('d-none');
                return;
              }

              gridEl.innerHTML = '';

              items.forEach(function (item) {
                var col = document.createElement('div');
                col.className = 'col-6 col-md-4';

                if (!item.mime_type) {
                  // 📁 PASTA
                  col.innerHTML = `
                    <div class="card media-card-select shadow-sm h-100" style="cursor:pointer;background:var(--surface);border-color:var(--border)"
                         onclick="entrarPastaMedia(${item.id})">
                      <div class="card-img-top d-flex align-items-center justify-content-center"
                           style="height:120px;font-size:3rem;background:var(--surface2)">📁</div>
                      <div class="card-body p-2 border-top" style="background:var(--surface)">
                        <div class="text-truncate small" style="color:var(--text)" title="${item.titulo}">
                          ${item.titulo}
                        </div>
                      </div>
                    </div>`;
                } else if (/\.(jpg|jpeg|png|gif|webp|svg)$/i.test(item.titulo)) {
                  // 🖼 IMAGEM
                  col.innerHTML = `
                    <div class="card media-card-select shadow-sm h-100" style="cursor:pointer;border-color:var(--border)"
                         onclick="selecionarImagemMedia('${item.ficheiro_url}', '${item.titulo.replace(/'/g, "\\'")}')">
                      <img src="${item.ficheiro_url}" class="card-img-top" style="height:120px;object-fit:cover" loading="lazy" alt="${item.titulo}">
                      <div class="card-body p-2 border-top" style="background:var(--surface)">
                        <div class="text-truncate small" style="color:var(--text)" title="${item.titulo}">
                          ${item.titulo}
                        </div>
                      </div>
                    </div>`;
                }
                // ficheiros não-imagem não são mostrados na biblioteca do editor

                if (col.innerHTML) gridEl.appendChild(col);
              });

              if (!gridEl.children.length) {
                emptyEl.classList.remove('d-none');
                return;
              }

              gridEl.classList.remove('d-none');
            })
            .catch(function (err) {
              console.error('Erro ao carregar media:', err);
              loadingEl.classList.add('d-none');
              emptyEl.classList.remove('d-none');
            });
        }

        function entrarPastaMedia(folderId) {
          mediaFolderStack.push(folderId);
          document.getElementById('media-back-btn').classList.remove('d-none');
          carregarMediaPasta(folderId);
        }

        // Selecionar e inserir imagem no Editor Visual
        function selecionarImagemMedia(url, titulo) {
          var editor = document.getElementById('editor-visual');
          editor.focus();

          // Inserir tag de imagem nativamente
          document.execCommand('insertImage', false, url);

          // Estilizar a imagem acabada de inserir
          var imagens = editor.getElementsByTagName('img');
          if (imagens.length > 0) {
            var ultimaImg = imagens[imagens.length - 1];
            ultimaImg.style.maxWidth = '100%';
            ultimaImg.style.height = 'auto';
            ultimaImg.style.borderRadius = '8px';
            ultimaImg.style.marginTop = '10px';
            ultimaImg.style.marginBottom = '10px';
            ultimaImg.alt = titulo;
          }

          sincronizarEditor();

          var offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('bibliotecaMediaOffcanvas'));
          offcanvas.hide();
        }

        let imagemSelecionada = null;
        const editorVisual = document.getElementById('editor-visual');

        // Ao clicar dentro do editor
        editorVisual.addEventListener('click', function (e) {
          if (e.target.tagName === 'IMG') {
            selecionarImagem(e.target);
          } else {
            removerSelecaoImagem();
          }
        });

        // Se o user escrever ou fizer scroll, esconde a barra para não atrapalhar
        editorVisual.addEventListener('input', removerSelecaoImagem);
        editorVisual.addEventListener('scroll', removerSelecaoImagem);

        function selecionarImagem(img) {
          removerSelecaoImagem(); // Limpa estado anterior
          imagemSelecionada = img;
          imagemSelecionada.classList.add('selected-img');

          const toolbar = document.getElementById('image-toolbar');
          toolbar.classList.remove('d-none');

          // Calcular a posição baseada no offset da imagem e do scroll do editor
          const topPos = img.offsetTop - editorVisual.scrollTop - 45;
          const leftPos = img.offsetLeft + (img.offsetWidth / 2) - (toolbar.offsetWidth / 2);

          // Impedir que a tooltip fuja do quadro (margem de segurança)
          toolbar.style.top = Math.max(10, topPos) + 'px';
          toolbar.style.left = Math.max(10, leftPos) + 'px';
        }

        function removerSelecaoImagem() {
          const toolbar = document.getElementById('image-toolbar');
          if (toolbar && !toolbar.classList.contains('d-none')) {
            toolbar.classList.add('d-none');
          }
          if (imagemSelecionada) {
            imagemSelecionada.classList.remove('selected-img');
            imagemSelecionada = null;
          }
        }

        function formatarImagem(acao) {
          if (!imagemSelecionada) return;

          // Fazer reset aos estilos flutuantes
          imagemSelecionada.style.float = '';
          imagemSelecionada.style.display = 'block';
          imagemSelecionada.style.margin = '10px 0';

          if (acao === 'esquerda') {
            imagemSelecionada.style.float = 'left';
            imagemSelecionada.style.margin = '0 15px 15px 0';
          } else if (acao === 'centro') {
            imagemSelecionada.style.display = 'block';
            imagemSelecionada.style.margin = '15px auto';
          } else if (acao === 'direita') {
            imagemSelecionada.style.float = 'right';
            imagemSelecionada.style.margin = '0 0 15px 15px';
          } else if (acao === 'remover') {
            imagemSelecionada.remove();
            removerSelecaoImagem();
          }
          // Se for "nenhum", mantém o reset padrão

          sincronizarEditor();

          // Se a imagem não foi apagada, recalcula a posição da tooltip
          if (imagemSelecionada) {
            selecionarImagem(imagemSelecionada);
          }
        }

        // Estilos CSS
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', addStyles);
        } else {
          addStyles();
        }

        function addStyles() {
          var style = document.createElement('style');
          style.textContent = `
            .media-card-select {
              transition: transform 0.2s, box-shadow 0.2s;
            }
            .media-card-select:hover {
              transform: translateY(-4px);
              box-shadow: 0 8px 16px rgba(0,0,0,0.3) !important;
            }
            #editor-visual:focus {
              outline: none;
            }
            #editor-visual img, #preview-visual img {
              max-width: 100%;
              height: auto;
              cursor: pointer;
            }
            .toolbar-btn.disabled {
              opacity: 0.4;
              cursor: not-allowed;
              pointer-events: none;
            }
            #btn-preview {
              white-space: nowrap;
            }

            #image-toolbar {
              position: absolute;
              z-index: 1050;
              border: 1px solid var(--border);
              border-radius: 0.375rem;
              padding: 0.25rem 0.5rem;
              display: flex;
              align-items: center;
              gap: 0.25rem;
              box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.2);
              transition: top 0.1s ease-out, left 0.1s ease-out;
            }

            #image-toolbar button {
              border: none;
              background: transparent;
            }
          `;
          document.head.appendChild(style);
        }
      </script>

      <%- include('../partials/admin-layout-end') %>
        <script>
          document.addEventListener('DOMContentLoaded', function () {
            // Handler para ícones chevron nas card-headers
            document.querySelectorAll('.card-header').forEach(header => {
              const chevron = header.querySelector('.bi-chevron-up, .bi-chevron-down');
              if (!chevron) return;
              chevron.style.cursor = 'pointer';
              header.addEventListener('click', function (e) {
                // evita interferir com botões/link internos
                if (e.target.closest('button, a')) return;
                // procura o body da card imediatamente a seguir
                let body = header.nextElementSibling;
                if (!body || !body.classList.contains('card-body')) {
                  body = header.parentElement.querySelector('.card-body');
                }
                if (!body) return;
                const hidden = body.classList.toggle('d-none');
                chevron.classList.toggle('bi-chevron-up', !hidden);
                chevron.classList.toggle('bi-chevron-down', hidden);
              });
            });
          });
        </script>