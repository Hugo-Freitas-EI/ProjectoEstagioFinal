<%- include('../partials/admin-layout', { pageTitle: pageTitle, currentPage: currentPage }) %>

<%
  // REMOVE ISTO se existir:
  // const base  = `/admin/posts/${postId}/revisions/compare`;

  // Mantém só cálculos que não colidam com locals:
  const total = revisions.length;
%>

<style>
.diff-del { background: rgba(220,53,69,.18); text-decoration: none; border-radius: 2px; }
.diff-ins { background: rgba(25,135,84,.18);  text-decoration: none; border-radius: 2px; }

.rev-bar {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  background: var(--surface, var(--bs-body-bg));
  border: 1px solid var(--border, var(--bs-border-color));
  border-radius: var(--radius, 12px);
  overflow: hidden;
  margin-bottom: 1.5rem;
}
.rev-bar-cell { padding: 14px 20px; font-size: 13px; }
.rev-bar-cell + .rev-bar-cell { border-left: 1px solid var(--border, var(--bs-border-color)); }
.rev-bar-center {
  display: flex; align-items: center; justify-content: center;
  padding: 0 16px;
  border-left: 1px solid var(--border, var(--bs-border-color));
  color: var(--text2, var(--bs-secondary-color));
}
.rev-author { font-weight: 600; color: var(--text, var(--bs-body-color)); font-size: 14px; }
.rev-time   { color: var(--accent2, var(--bs-primary)); font-size: 12px; margin-top: 2px; font-family: 'DM Mono', monospace; }
.rev-date   { color: var(--text2, var(--bs-secondary-color)); font-size: 11px; font-family: 'DM Mono', monospace; }
.rev-current-badge {
  display: inline-block;
  font-size: 10px;
  font-family: 'DM Mono', monospace;
  text-transform: uppercase;
  letter-spacing: 1px;
  padding: 2px 8px;
  border-radius: 20px;
  background: rgba(74,222,128,.12);
  color: var(--success, #198754);
  border: 1px solid rgba(74,222,128,.3);
  margin-top: 4px;
}

.rev-slider {
  -webkit-appearance: none; appearance: none;
  width: 100%; height: 4px;
  background: var(--border, var(--bs-border-color));
  border-radius: 2px; outline: none; cursor: pointer;
}
.rev-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 20px; height: 20px; border-radius: 50%;
  background: var(--accent, var(--bs-primary));
  border: 3px solid var(--surface, var(--bs-body-bg));
  box-shadow: 0 0 0 2px var(--accent, var(--bs-primary));
  cursor: pointer; transition: background .15s;
}
.rev-slider::-webkit-slider-thumb:hover { background: var(--accent2, var(--bs-primary)); }
.rev-slider::-moz-range-thumb {
  width: 20px; height: 20px; border-radius: 50%;
  background: var(--accent, var(--bs-primary));
  border: 3px solid var(--surface, var(--bs-body-bg));
  cursor: pointer;
}

.diff-block {
  background: var(--surface, var(--bs-body-bg));
  border: 1px solid var(--border, var(--bs-border-color));
  border-radius: var(--radius, 12px);
  overflow: hidden; margin-bottom: 1.25rem;
}
.diff-block-head {
  padding: 10px 18px; font-weight: 600; font-size: 14px;
  border-bottom: 1px solid var(--border, var(--bs-border-color));
  background: var(--surface2, rgba(255,255,255,.03));
}
.diff-cols { display: grid; grid-template-columns: 1fr 1fr; }
.diff-col { padding: 16px 18px; min-height: 80px; }
.diff-col + .diff-col { border-left: 1px solid var(--border, var(--bs-border-color)); }
.diff-col-label {
  font-size: 11px; font-family: 'DM Mono', monospace;
  text-transform: uppercase; letter-spacing: 1px;
  color: var(--text2, var(--bs-secondary-color));
  text-align: center; margin-bottom: 10px; font-weight: 600;
}
.diff-col-label.removed { color: var(--danger, #dc3545); }
.diff-col-label.added   { color: var(--success, #198754); }
.diff-box {
  white-space: pre-wrap; font-family: 'DM Mono', monospace;
  font-size: 13px; line-height: 1.65;
  color: var(--text, var(--bs-body-color)); word-break: break-word;
}
.diff-no-change {
  color: var(--text2, var(--bs-secondary-color));
  font-style: italic; font-size: 13px; padding: 8px 0;
}

.rev-nav {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: 1.5rem;
}
.compare-toggle {
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; color: var(--text2, var(--bs-secondary-color));
  cursor: pointer; user-select: none;
}
.compare-toggle input { cursor: pointer; width: 15px; height: 15px; accent-color: var(--accent, var(--bs-primary)); }
.btn-restore {
  font-size: 12px; padding: 4px 12px; border-radius: 6px;
  background: transparent; border: 1px solid var(--border, var(--bs-border-color));
  color: var(--text2, var(--bs-secondary-color));
  cursor: pointer; transition: all .15s; text-decoration: none;
}
.btn-restore:hover {
  background: var(--accent, var(--bs-primary));
  border-color: var(--accent, var(--bs-primary)); color: #fff;
}
</style>

<%
  const base  = `/admin/posts/${postId}/revisions/compare`;
  const editUrl = `/admin/posts/${postId}/edit`;
  const restoreBase = `/admin/posts/${postId}/revisions`;
  // slider: esquerda = mais antiga (pos=0), direita = mais recente (pos=total-1)
  // "Anterior" recua no tempo (pos-1), "Seguinte" avança no tempo (pos+1)
  const prevPos = currentPos - 1;
  const nextPos = currentPos + 1;
  const prevUrl = prevPos >= 0    ? `${base}?pos=${prevPos}` : null;
  const nextUrl = nextPos < total ? `${base}?pos=${nextPos}` : null;

  // Info da revisão esquerda e direita para a barra de info
  const leftInfo  = revisions.find(r => Number(r.ID || r.id) === Number(leftId));
  const rightInfo = revisions.find(r => Number(r.ID || r.id) === Number(rightId));
%>

<div style="max-width:1100px">

  <div class="mb-3">
    <h4 class="mb-1" style="font-family:'DM Serif Display',serif">
      Comparar as revisões de "<a href="<%= editUrl %>" style="color:var(--accent2, var(--bs-primary))"><%= postTitle %></a>"
    </h4>
    <a href="<%= editUrl %>" style="font-size:13px;color:var(--text2, var(--bs-secondary-color))">← Ir para o editor</a>
  </div>

  <% if (!total) { %>
    <div class="alert alert-warning">Este post ainda não tem revisões guardadas.</div>
  <% } else { %>

    <!-- Navegação -->
    <div class="rev-nav">
      <% if (prevUrl) { %>
        <a href="<%= prevUrl %>" class="btn btn-sm btn-outline-secondary">← Anterior</a>
      <% } else { %>
        <button class="btn btn-sm btn-outline-secondary" disabled>← Anterior</button>
      <% } %>

      <% if (!compareMode) { %>
        <form method="GET" action="<%= base %>" style="flex:1;margin:0 20px">
          <input
            type="range"
            class="rev-slider"
            id="rev-slider"
            name="pos"
            min="0"
            max="<%= total - 1 %>"
            step="1"
            value="<%= currentPos %>"
            onchange="this.form.submit()">
        </form>
      <% } else { %>
        <div style="flex:1"></div>
      <% } %>

      <div class="d-flex align-items-center gap-3">
    <label class="compare-toggle">
      <input
        type="checkbox"
        id="compare-toggle"
        <%= compareMode ? 'checked' : '' %>
        onchange="toggleCompareMode(this.checked)">
      Comparar quaisquer duas revisões
    </label>

        <% if (nextUrl) { %>
          <a href="<%= nextUrl %>" class="btn btn-sm btn-outline-secondary">Seguinte →</a>
        <% } else { %>
          <button class="btn btn-sm btn-outline-secondary" disabled>Seguinte →</button>
        <% } %>
      </div>
    </div>

    <!-- Selects (modo comparar dois quaisquer) -->
    <div id="compare-selects" <%= compareMode ? '' : 'hidden' %>>
      <form method="GET" action="<%= base %>"
        class="d-flex gap-3 align-items-end mb-4 flex-wrap">
        <input type="hidden" name="compare" value="1">
        <div style="flex:1;min-width:260px">
          <label class="form-label">Revisão (esquerda — mais antiga)</label>
          <select class="form-select form-select-sm" name="left" id="left-select">
            <% revisions.forEach(function(r, idx) { const rid = r.ID || r.id; %>
              <% if (idx < revisions.length - 1) { %>
                <option value="<%= rid %>" <%= Number(rid) === Number(leftId) ? 'selected' : '' %>>
                  #<%= rid %> · <%= r.author_name || 'Autor' %> · <%= r.timeAgo %> (<%= r.exactDateFormatted %>)
                </option>
              <% } %>
            <% }) %>
          </select>
          <div class="form-text">Escolhe primeiro a revisão da esquerda.</div>
        </div>
        <div style="flex:1;min-width:260px">
          <label class="form-label">Revisão (direita — mais recente)</label>
          <select class="form-select form-select-sm" name="right" id="right-select" disabled>
            <option value="">— Seleciona a revisão da esquerda primeiro —</option>
          </select>
          <div class="form-text">A direita só mostra revisões mais recentes.</div>
        </div>
        <button type="submit" class="btn btn-sm btn-primary" id="compare-submit" disabled>Comparar</button>
      </form>
    </div>

    <% if (!leftRev || !rightRev) { %>
      <div class="alert alert-warning">Escolhe duas revisões válidas para comparar.</div>
    <% } else { %>

      <!-- Info bar -->
      <div class="rev-bar">

        <!-- Esquerda: sempre uma revisão -->
        <div class="rev-bar-cell">
          <div class="rev-author"><%= leftRev.author_name || 'Autor desconhecido' %></div>
          <div class="rev-time"><%= leftInfo?.timeAgo || '' %></div>
          <div class="rev-date"><%= leftInfo?.exactDateFormatted || '' %></div>
        </div>

        <div class="rev-bar-center">
          <i class="bi bi-arrow-left-right" style="font-size:1.1rem"></i>
        </div>

        <!-- Direita: revisão ou estado atual do post -->
        <div class="rev-bar-cell d-flex align-items-start justify-content-between">
          <div>
            <div class="rev-author"><%= rightRev.author_name || 'Autor desconhecido' %></div>
            <% if (rightIsCurrentPost) { %>
              <div class="rev-current-badge">Versão atual</div>
              <div class="rev-date" style="margin-top:4px">
                <%# data de modificação do post atual %>
                <%= rightRev.post_modified
                      ? new Date(rightRev.post_modified).toLocaleString('pt-PT', {
                          day:'2-digit', month:'long', year:'numeric',
                          hour:'2-digit', minute:'2-digit'
                        })
                      : '' %>
              </div>
            <% } else { %>
              <div class="rev-time"><%= rightInfo?.timeAgo || '' %></div>
              <div class="rev-date"><%= rightInfo?.exactDateFormatted || '' %></div>
            <% } %>
          </div>

          <%# Botão repor: só aparece quando o lado direito é uma revisão (não o estado atual) %>
          <% if (!rightIsCurrentPost) { %>
            <form method="POST"
              action="<%= restoreBase %>/<%= rightId %>/restore"
              onsubmit="return confirm('Repor esta revisão? O conteúdo actual será substituído.')">
              <button type="submit" class="btn-restore">Repor esta revisão</button>
            </form>
          <% } %>
        </div>

      </div>

      <!-- Diff Título -->
      <div class="diff-block">
        <div class="diff-block-head">Título</div>
        <div class="diff-cols">
          <div class="diff-col">
            <div class="diff-col-label removed">Removido</div>
            <% if (titleDiff.hasChanges) { %>
              <div class="diff-box"><%- titleDiff.left %></div>
            <% } else { %>
              <div class="diff-box"><%= leftRev.post_title %></div>
            <% } %>
          </div>
          <div class="diff-col">
            <div class="diff-col-label added">Adicionado</div>
            <% if (titleDiff.hasChanges) { %>
              <div class="diff-box"><%- titleDiff.right %></div>
            <% } else { %>
              <div class="diff-no-change">Sem alterações</div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Diff Conteúdo -->
      <div class="diff-block">
        <div class="diff-block-head">Conteúdo</div>
        <div class="diff-cols">
          <div class="diff-col">
            <div class="diff-col-label removed">Removido</div>
            <div class="diff-box"><%- contentDiff.left %></div>
          </div>
          <div class="diff-col">
            <div class="diff-col-label added">Adicionado</div>
            <% if (contentDiff.hasChanges) { %>
              <div class="diff-box"><%- contentDiff.right %></div>
            <% } else { %>
              <div class="diff-no-change">Sem alterações no conteúdo</div>
            <% } %>
          </div>
        </div>
      </div>

    <% } %>
  <% } %>
</div>

<script type="application/json" id="rev-compare-data"><%- JSON.stringify({
  base,
  compareMode,
  currentPos,
  leftId: Number(leftId || 0),
  rightId: Number(rightId || 0),
  revisions: (revisions || []).map(r => ({
    id: Number(r.ID || r.id),
    label: `#${Number(r.ID || r.id)} · ${(r.author_name || 'Autor')} · ${(r.timeAgo || '')} (${(r.exactDateFormatted || '')})`
  }))
}) %></script>

<script>
(function () {
  const dataEl = document.getElementById('rev-compare-data');
  if (!dataEl) return;

  const data = JSON.parse(dataEl.textContent || '{}');

  // ✅ ATIVAR sempre o toggle (mesmo quando compareMode=false)
  const base = String(data.base || '');
  const currentPos = Number(data.currentPos || 0);

  window.toggleCompareMode = function (checked) {
    if (!base) return;

    if (checked) {
      // entra no modo comparar (server-side)
      const leftId = Number(data.leftId || 0);
      const rightId = Number(data.rightId || 0);
      window.location.href =
        base +
        '?compare=1&left=' + encodeURIComponent(leftId) +
        '&right=' + encodeURIComponent(rightId);
      return;
    }

    // volta ao modo slider (server-side)
    window.location.href = base + '?pos=' + encodeURIComponent(currentPos);
  };

  // A partir daqui, mantém a tua lógica atual só para quando compareMode=true
  if (!data.compareMode) return;

  const revs = Array.isArray(data.revisions) ? data.revisions : [];
  const leftSel = document.getElementById('left-select');
  const rightSel = document.getElementById('right-select');
  const submitBtn = document.getElementById('compare-submit');

  if (!leftSel || !rightSel || !submitBtn) return;

  const idxById = new Map(revs.map((r, idx) => [Number(r.id), idx]));

  function rebuildRight() {
    const leftId = Number(leftSel.value);
    const leftIdx = idxById.get(leftId);

    rightSel.innerHTML = '';

    if (leftIdx == null) {
      rightSel.disabled = true;
      submitBtn.disabled = true;
      rightSel.appendChild(new Option('— Seleciona a revisão da esquerda primeiro —', ''));
      return;
    }

    const candidates = revs.slice(leftIdx + 1); // só mais recentes

    if (!candidates.length) {
      rightSel.disabled = true;
      submitBtn.disabled = true;
      rightSel.appendChild(new Option('— Não existem revisões mais recentes —', ''));
      return;
    }

    for (const r of candidates) {
      rightSel.appendChild(new Option(r.label, String(r.id)));
    }

    // Mantém rightId se ainda for válido; senão escolhe a primeira opção possível
    const desiredRight = Number(data.rightId || 0);
    const desiredIdx = idxById.get(desiredRight);

    if (desiredIdx != null && desiredIdx > leftIdx) {
      rightSel.value = String(desiredRight);
    } else {
      rightSel.selectedIndex = 0;
    }

    rightSel.disabled = false;
    submitBtn.disabled = !rightSel.value;
  }

  leftSel.addEventListener('change', () => {
    // quando muda a esquerda, deixa de “fixar” o rightId antigo
    data.rightId = 0;
    rebuildRight();
  });

  rightSel.addEventListener('change', () => {
    submitBtn.disabled = !rightSel.value;
  });

  rebuildRight();
})();
</script>
