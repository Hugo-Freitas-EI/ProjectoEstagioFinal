<%- include('../partials/admin-layout', { pageTitle: pageTitle, currentPage: 'users' }) %>

<div class="row"><div class="col-lg-6">
  <% if (error) { %><div class="alert alert-danger mb-3"><%= error %></div><% } %>

  <div class="card mb-3">
    <div class="card-header"><%= isEdit ? 'Editar Utilizador' : 'Novo Utilizador' %></div>
    <div class="card-body">
      <form method="POST" action="/admin/users<%= isEdit ? '/' + editUser.id : '' %>" data-unsaved>

        <div class="mb-3">
          <label class="form-label">Nome de utilizador *</label>
          <input type="text" name="username" class="form-control"
            value="<%= editUser ? editUser.username : '' %>" required autofocus>
        </div>

        <div class="mb-3">
          <label class="form-label">Email *</label>
          <input type="text" name="email" class="form-control"
            value="<%= editUser ? editUser.email : '' %>" required>
        </div>

        <div class="mb-3">
          <label class="form-label">Função</label>
          <select name="role" class="form-select">
            <% roles.forEach(function(r) { %>
              <option value="<%= r.name %>" <%= (editUser ? editUser.role : 'subscriber') === r.name ? 'selected' : '' %>>
                <%= r.label %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label">
            Password<% if (isEdit) { %> <span class="text-muted">(deixar em branco para não alterar)</span><% } else { %> *<% } %>
          </label>
          <div class="input-group">
            <input type="password" name="password" id="passwordField" class="form-control"
              <%= isEdit ? '' : 'required' %> minlength="6" autocomplete="new-password">
            <button type="button" class="btn btn-outline-secondary" id="togglePassword" tabindex="-1">
              <i class="bi bi-eye" id="toggleIcon"></i>
            </button>
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label">Confirmar password<% if (!isEdit) { %> *<% } %></label>
          <div class="input-group">
            <input type="password" id="passwordConfirm" class="form-control"
              <%= isEdit ? '' : 'required' %> minlength="6" autocomplete="new-password"
              placeholder="Repetir password">
            <button type="button" class="btn btn-outline-secondary" id="toggleConfirm" tabindex="-1">
              <i class="bi bi-eye" id="toggleIconConfirm"></i>
            </button>
          </div>
          <div id="passwordMismatch" class="text-danger mt-1 d-none" style="font-size:13px">As passwords não coincidem.</div>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i> <%= isEdit ? 'Guardar' : 'Criar' %>
          </button>
          <a href="/admin/users" class="btn btn-outline-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>

</div></div>

<script>
function toggleVis(fieldId, iconId) {
  var field = document.getElementById(fieldId);
  var icon  = document.getElementById(iconId);
  if (field.type === 'password') {
    field.type = 'text';
    icon.className = 'bi bi-eye-slash';
  } else {
    field.type = 'password';
    icon.className = 'bi bi-eye';
  }
}
document.getElementById('togglePassword').addEventListener('click', function() { toggleVis('passwordField', 'toggleIcon'); });
document.getElementById('toggleConfirm').addEventListener('click', function() { toggleVis('passwordConfirm', 'toggleIconConfirm'); });

var pwField   = document.getElementById('passwordField');
var pwConfirm = document.getElementById('passwordConfirm');
var mismatch  = document.getElementById('passwordMismatch');

function checkMatch() {
  if (!pwField.value && !pwConfirm.value) { mismatch.classList.add('d-none'); return; }
  if (pwField.value !== pwConfirm.value) {
    mismatch.classList.remove('d-none');
  } else {
    mismatch.classList.add('d-none');
  }
}
pwField.addEventListener('input', checkMatch);
pwConfirm.addEventListener('input', checkMatch);

document.querySelector('form').addEventListener('submit', function(e) {
  if (pwField.value !== pwConfirm.value) {
    e.preventDefault();
    mismatch.classList.remove('d-none');
    pwConfirm.focus();
  }
});
</script>

<%- include('../partials/admin-layout-end') %>
