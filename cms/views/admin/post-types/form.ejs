<%- include('../../partials/admin-layout', { pageTitle: pageTitle, currentPage: 'post-types' }) %>

<div class="row"><div class="col-lg-7">
  <% if (error) { %><div class="alert alert-danger mb-3"><%= error %></div><% } %>

  <div class="card mb-3">
    <div class="card-header"><%= isEdit ? 'Editar Tipo de Conteúdo' : 'Novo Tipo de Conteúdo' %></div>
    <div class="card-body">
      <form method="POST" action="/admin/post-types<%= isEdit ? '/' + postType.name : '' %>">

        <div class="mb-3">
          <label class="form-label">Label (aparece na sidebar) *</label>
          <input type="text" name="label" class="form-control"
            value="<%= postType ? postType.label : '' %>"
            placeholder="Ex: Produtos, Eventos, Noticias"
            oninput="gerarName(this.value)"
            required autofocus>
        </div>

        <div class="mb-3">
          <label class="form-label">
            Name (slug interno)
            <span class="text-muted" style="text-transform:none;letter-spacing:0;font-size:11px">
              — usado no URL e na BD
            </span>
          </label>
          <input type="text" name="name" id="pt-name" class="form-control"
            value="<%= postType ? postType.name : '' %>"
            placeholder="produto, evento, noticia"
            data-edited="<%= isEdit ? 'true' : 'false' %>"
            <%= isEdit ? 'readonly' : '' %>>
          <div class="form-text">
            <%= isEdit ? 'O name não pode ser alterado após criação.' : 'Gerado automaticamente do label. Só letras, números e _.' %>
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label">Descrição</label>
          <textarea name="description" class="form-control" style="min-height:70px"><%= postType ? (postType.description || '') : '' %></textarea>
        </div>

        <!-- Taxonomias associadas -->
        <% if (categories && categories.length) { %>
          <div class="mb-4">
            <label class="form-label">
              Taxonomias associadas
              <span class="text-muted" style="text-transform:none;letter-spacing:0;font-size:11px">
                — aparecem no editor deste tipo
              </span>
            </label>
            <div class="d-flex flex-column gap-1 p-3 rounded" style="background:var(--surface2);border:1px solid var(--border)">
              <% categories.forEach(function(c) { %>
                <div class="form-check">
                  <input type="checkbox" name="category_ids[]" value="<%= c.id %>"
                    class="form-check-input" id="cat_<%= c.id %>"
                    <%= selectedCategoryIds.map(Number).includes(Number(c.id)) ? 'checked' : '' %>>
                  <label class="form-check-label" for="cat_<%= c.id %>" style="font-size:13px">
                    <%= c.name %>
                    <% if (c.description) { %>
                      <span class="text-muted">— <%= c.description %></span>
                    <% } %>
                  </label>
                </div>
              <% }) %>
            </div>
            <div class="form-text">
              Sem categorias? <a href="/admin/categories/new" target="_blank">Criar uma categoria</a> primeiro.
            </div>
          </div>
        <% } %>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i> <%= isEdit ? 'Guardar' : 'Criar' %>
          </button>
          <a href="/admin/post-types" class="btn btn-outline-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>

  <% if (isEdit) { %>
    <div class="card">
      <div class="card-header" style="color:var(--danger)">Zona de Perigo</div>
      <div class="card-body">
        <p class="text-muted small mb-2">
          Desativa o tipo. Os posts existentes não são apagados e continuam na BD.
        </p>
        <form method="POST" action="/admin/post-types/<%= postType.name %>/delete"
          onsubmit="return confirm('Desativar este tipo de conteúdo?')">
          <button type="submit" class="btn btn-sm btn-outline-danger">
            <i class="bi bi-trash me-1"></i> Desativar tipo
          </button>
        </form>
      </div>
    </div>
  <% } %>

</div></div>

<script>
var ptNameEl = document.getElementById('pt-name');
var nameEdited = ptNameEl ? ptNameEl.dataset.edited === 'true' : false;
if (ptNameEl) {
  ptNameEl.addEventListener('input', function() {
    nameEdited = true;
  });
}

function gerarName(val) {
  if (nameEdited) return;
  var slug = val.toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '_')
    .replace(/^_|_$/g, '');
  var el = document.getElementById('pt-name');
  if (el && !el.readOnly) el.value = slug;
}
</script>

<%- include('../../partials/admin-layout-end') %>
