<%- include('../../partials/admin-layout', { pageTitle: pageTitle, currentPage: 'terms' }) %>

<div class="row"><div class="col-lg-6">
  <% if (error) { %><div class="alert alert-danger mb-3"><%= error %></div><% } %>

  <div class="card">
    <div class="card-header"><%= isEdit ? 'Editar Termo' : 'Novo Termo' %></div>
    <div class="card-body">
      <form method="POST" action="/admin/terms<%= isEdit ? '/' + term.id : '' %>">
        <div class="mb-3">
          <label class="form-label">Categoria *</label>
          <select name="category_id" class="form-select" required>
            <option value="">— selecionar —</option>
            <% categories.forEach(function(c) { %>
              <option value="<%= c.id %>"
                <%= (term ? term.category_id : preselectedCategoryId) == c.id ? 'selected' : '' %>>
                <%= c.name %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Nome *</label>
          <input type="text" name="name" class="form-control" value="<%= term ? term.name : '' %>" required autofocus>
        </div>
        <div class="mb-3">
          <label class="form-label">Slug</label>
          <input type="text" name="slug" class="form-control" value="<%= term ? term.slug : '' %>" placeholder="gerado automaticamente">
        </div>
        <div class="mb-4">
          <label class="form-label">Descrição</label>
          <textarea name="description" class="form-control" style="min-height:70px"><%= term ? term.description : '' %></textarea>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i><%= isEdit ? 'Guardar' : 'Criar' %></button>
          <a href="/admin/terms" class="btn btn-outline-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
</div></div>

<%- include('../../partials/admin-layout-end') %>
