<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Esqueceu a password · NodeCMS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body>
<div class="auth-page">
  <div class="auth-card">
    <span class="auth-logo">NodeCMS</span>
    <p class="auth-sub">Recuperar password</p>

    <% if (error) { %>
      <div class="alert alert-danger mb-3"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success mb-3"><%= success %></div>
    <% } %>

    <% if (!success) { %>
    <form method="POST" action="/admin/forgot-password">
      <div class="mb-4">
        <label class="form-label">Email da conta</label>
        <input type="email" name="email" class="form-control" placeholder="o-teu@email.com" required autofocus>
      </div>
      <button type="submit" class="btn btn-primary w-100" style="padding:10px">Enviar link de recuperação</button>
    </form>
    <% } %>

    <div class="text-center mt-3" style="font-size:13px">
      <a href="/admin/login" style="color:var(--accent2)">← Voltar ao login</a>
    </div>
  </div>
</div>
</body>
</html>
