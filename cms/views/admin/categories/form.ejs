<%- include('../../partials/admin-layout', { pageTitle: pageTitle, currentPage: 'categories' }) %>

<div class="row"><div class="col-lg-6">
  <% if (error) { %><div class="alert alert-danger mb-3"><%= error %></div><% } %>

  <div class="card">
    <div class="card-header"><%= isEdit ? 'Editar Categoria' : 'Nova Categoria' %></div>
    <div class="card-body">
      <form method="POST" action="/admin/categories<%= isEdit ? '/' + category.id : '' %>">
        <div class="mb-3">
          <label class="form-label">Nome *</label>
          <input type="text" name="name" class="form-control" value="<%= category ? category.name : '' %>" required autofocus>
        </div>
        <div class="mb-3">
          <label class="form-label">Slug</label>
          <input type="text" name="slug" class="form-control" value="<%= category ? category.slug : '' %>" placeholder="gerado automaticamente">
        </div>
        <div class="mb-4">
          <label class="form-label">Descrição</label>
          <textarea name="description" class="form-control" style="min-height:80px"><%= category ? category.description : '' %></textarea>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i><%= isEdit ? 'Guardar' : 'Criar' %></button>
          <a href="/admin/categories" class="btn btn-outline-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
</div></div>

<%- include('../../partials/admin-layout-end') %>
