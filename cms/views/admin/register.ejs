<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Criar Conta · NodeCMS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body>
<div class="auth-page">
  <div class="auth-card">
    <span class="auth-logo">NodeCMS</span>
    <p class="auth-sub">Criar conta de administrador</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger mb-3"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/register">
      <div class="mb-3">
        <label class="form-label">Nome de utilizador</label>
        <input type="text" name="username" class="form-control" placeholder="O teu nome" required autofocus>
      </div>
      <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" placeholder="admin@site.com" required>
      </div>
      <div class="mb-4">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="Mínimo 8 caracteres" required minlength="8">
      </div>
      <button type="submit" class="btn btn-primary w-100" style="padding:10px">Criar Conta</button>
    </form>

    <div class="text-center mt-3" style="font-size:13px">
      <span style="color:var(--text2)">Já tens conta?</span>
      <a href="/admin/login" style="color:var(--accent2);margin-left:4px">Entrar</a>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
