<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' · ' : '' %>NodeCMS Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body>
<div class="d-flex">

  <aside class="sidebar">
    <div class="sidebar-logo">
      <h1>NodeCMS</h1>
      <span>Painel Admin</span>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">Principal</div>
      <a href="/admin" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
        <i class="bi bi-grid"></i><span>Dashboard</span>
      </a>
      <div class="nav-section">Conteúdo</div>
      <a href="/admin/posts" class="nav-item <%= currentPage === 'posts' ? 'active' : '' %>">
        <i class="bi bi-pencil-square"></i><span>Posts</span>
      </a>
      <a href="/admin/pages" class="nav-item <%= currentPage === 'pages' ? 'active' : '' %>">
        <i class="bi bi-file-text"></i><span>Páginas</span>
      </a>
      <a href="/admin/media" class="nav-item <%= currentPage === 'media' ? 'active' : '' %>">
        <i class="bi bi-images"></i><span>Media</span>
      </a>

      <!--<div class="nav-section">Taxonomias</div>
      <a href="/admin/categories" class="nav-item <%= currentPage === 'categories' ? 'active' : '' %>">
        <i class="bi bi-folder"></i><span>Categorias</span>
      </a>
      <a href="/admin/terms" class="nav-item <%= currentPage === 'terms' ? 'active' : '' %>">
        <i class="bi bi-tag"></i><span>Termos</span>
      </a>

      <div class="nav-section">Estrutura</div>
      <a href="/admin/field-groups" class="nav-item <%= currentPage === 'field-groups' ? 'active' : '' %>">
        <i class="bi bi-sliders"></i><span>Custom Fields</span>
      </a>-->

      <div class="nav-section">Gestão</div>
      <a href="/admin/users" class="nav-item <%= currentPage === 'users' ? 'active' : '' %>">
        <i class="bi bi-people"></i><span>Utilizadores</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <% if (user) { %>
        <div class="d-flex align-items-center gap-2">
          <div class="user-avatar"><%= user.username[0].toUpperCase() %></div>
          <div>
            <div class="username"><%= user.username %></div>
            <div class="role"><%= user.role %></div>
          </div>
        </div>
      <% } %>
    </div>
  </aside>

  <div class="main-content">
    <div class="topbar">
      <h1><%= typeof pageTitle !== 'undefined' ? pageTitle : '' %></h1>
      <div class="d-flex gap-2">
        <!--<a href="/" target="_blank" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-box-arrow-up-right"></i> Ver Site
        </a>-->
        <a href="" target="" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-box-arrow-up-right"></i> Ver Site
        </a>
        <a href="/admin/logout" class="btn btn-sm btn-outline-danger">
          <i class="bi bi-box-arrow-right"></i> Sair
        </a>
      </div>
    </div>

    <div class="page-body">
      <% if (typeof flash !== 'undefined' && flash.length > 0) { %>
        <% flash.forEach(function(f) { %>
          <div class="alert alert-<%= f.type === 'success' ? 'success' : 'danger' %> alert-dismissible d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-<%= f.type === 'success' ? 'check-circle' : 'exclamation-circle' %>"></i>
            <%= f.msg %>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
          </div>
        <% }) %>
      <% } %>
