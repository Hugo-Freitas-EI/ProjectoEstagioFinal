<!DOCTYPE html>
<html lang="pt">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= typeof pageTitle !=='undefined' ? pageTitle + ' · ' : '' %>NodeCMS Admin
  </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
  <% if (siteLogoUrl) { %>
  <link rel="icon" href="<%= siteLogoUrl %>">
  <% } %>
  <script>(function(){var t=localStorage.getItem('theme');if(t==='light'||t==='dark')document.documentElement.style.colorScheme=t;}());</script>
</head>

<body>
  <div class="d-flex">

    <aside class="sidebar" id="sidebar">
      <div class="sidebar-logo">
        <h1 class="sidebar-title">NodeCMS</h1>
        <span class="sidebar-subtitle"><%= user && user.role === 'admin' ? 'Painel Admin' : 'Painel ' + (user && user.role ? user.role.charAt(0).toUpperCase() + user.role.slice(1) : '') %></span>
        <button class="sidebar-toggle" id="sidebarToggle" title="Minimizar sidebar">
          <i class="bi bi-layout-sidebar-reverse" id="sidebarToggleIcon"></i>
        </button>
      </div>

      <nav class="sidebar-nav">

        <div class="nav-section">Principal</div>
        <a href="/admin" title="Dashboard" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
          <i class="bi bi-grid"></i><span>Dashboard</span>
        </a>

        <% var p = (user && user.permissions) ? user.permissions : []; %>
        <% var has = function(k) { return p.includes(k+'.read') || p.includes(k+'.write'); }; %>

        <%
          var hasCpt = user && user.role === 'admin'
            ? (typeof customPostTypes !== 'undefined' && customPostTypes.length > 0)
            : (typeof customPostTypes !== 'undefined' && customPostTypes.some(function(c){ return has('cpt.'+c.name); }));
        %>
        <% if (has('posts') || has('pages') || has('media') || hasCpt) { %>
        <div class="nav-section">Conteúdo</div>
        <% var sysPost = (typeof systemPostTypes !== 'undefined' && systemPostTypes[0]) ? systemPostTypes[0] : { name: 'post', label: 'Posts' }; %>
        <% var sysPage = (typeof systemPostTypes !== 'undefined' && systemPostTypes[1]) ? systemPostTypes[1] : { name: 'page', label: 'Páginas' }; %>
        <% if (has('posts')) { %>
        <a href="/admin/cpt/<%= sysPost.name %>" title="<%= sysPost.label %>" class="nav-item <%= currentPage === sysPost.name ? 'active' : '' %>">
          <i class="bi bi-pencil-square"></i><span><%= sysPost.label %></span>
        </a>
        <% } %>
        <% if (has('pages')) { %>
        <a href="/admin/cpt/<%= sysPage.name %>" title="<%= sysPage.label %>" class="nav-item <%= currentPage === sysPage.name ? 'active' : '' %>">
          <i class="bi bi-file-text"></i><span><%= sysPage.label %></span>
        </a>
        <% } %>
        <% if (has('media')) { %>
        <a href="/admin/media" title="Media" class="nav-item <%= currentPage === 'media' ? 'active' : '' %>">
          <i class="bi bi-images"></i><span>Media</span>
        </a>
        <% } %>
        <% if (typeof customPostTypes !== 'undefined' && customPostTypes.length) { %>
          <% customPostTypes.forEach(function(cpt) { %>
            <% if (user && user.role === 'admin' || has('cpt.' + cpt.name)) { %>
              <a href="/admin/cpt/<%= cpt.name %>" title="<%= cpt.label %>"
                class="nav-item <%= currentPage === cpt.name ? 'active' : '' %>">
                <i class="bi bi-collection"></i><span><%= cpt.label %></span>
              </a>
            <% } %>
          <% }) %>
        <% } %>
        <% } %>

        <% if (has('categories') || has('terms')) { %>
        <div class="nav-section">Taxonomias</div>
        <% if (has('categories')) { %>
        <a href="/admin/categories" title="Categorias" class="nav-item <%= currentPage === 'categories' ? 'active' : '' %>">
          <i class="bi bi-folder"></i><span>Categorias</span>
        </a>
        <% } %>
        <% if (has('terms')) { %>
        <a href="/admin/terms" title="Termos" class="nav-item <%= currentPage === 'terms' ? 'active' : '' %>">
          <i class="bi bi-tag"></i><span>Termos</span>
        </a>
        <% } %>
        <% } %>

        <% if (has('menus')) { %>
        <div class="nav-section">Aparência</div>
        <a href="/admin/menus" title="Menus" class="nav-item <%= currentPage === 'menus' ? 'active' : '' %>">
          <i class="bi bi-list-nested"></i><span>Menus</span>
        </a>
        <% } %>

        <% if (has('post-types') || has('field-groups')) { %>
        <div class="nav-section">Estrutura</div>
        <% if (has('post-types')) { %>
        <a href="/admin/post-types" title="Tipos de Conteúdo" class="nav-item <%= currentPage === 'post-types' ? 'active' : '' %>">
          <i class="bi bi-collection-fill"></i><span>Tipos de Conteúdo</span>
        </a>
        <% } %>
        <% if (has('field-groups')) { %>
        <a href="/admin/field-groups" title="Custom Fields" class="nav-item <%= currentPage === 'field-groups' ? 'active' : '' %>">
          <i class="bi bi-sliders"></i><span>Custom Fields</span>
        </a>
        <% } %>
        <% } %>

        <% if (has('users') || has('roles') || has('settings')) { %>
        <div class="nav-section">Gestão</div>
        <% if (has('users')) { %>
        <a href="/admin/users" title="Utilizadores" class="nav-item <%= currentPage === 'users' ? 'active' : '' %>">
          <i class="bi bi-people"></i><span>Utilizadores</span>
        </a>
        <% } %>
        <% if (has('roles')) { %>
        <a href="/admin/roles" title="Funções" class="nav-item <%= currentPage === 'roles' ? 'active' : '' %>">
          <i class="bi bi-shield-lock"></i><span>Funções</span>
        </a>
        <% } %>
        <% if (has('settings')) { %>
        <a href="/admin/settings" title="Definições" class="nav-item <%= currentPage === 'settings' ? 'active' : '' %>">
          <i class="bi bi-gear"></i><span>Definições</span>
        </a>
        <% } %>
        <% } %>

      </nav>

      <div class="sidebar-footer">
        <% if (user) { %>
          <a href="/admin/profile" class="d-flex align-items-center gap-2 sidebar-profile-link">
            <div class="user-avatar">
              <%= user.username[0].toUpperCase() %>
            </div>
            <div>
              <div class="username"><%= user.username %></div>
              <div class="role"><%= user.roleLabel || (user.role ? user.role.charAt(0).toUpperCase() + user.role.slice(1) : '') %></div>
            </div>
          </a>
        <% } %>
      </div>
    </aside>

    <div class="main-content" id="mainContent">
      <div class="topbar">
        <h1>
          <%= typeof pageTitle !=='undefined' ? pageTitle : '' %>
        </h1>
        <div class="d-flex gap-2 align-items-center">
          <button id="theme-toggle" class="btn btn-sm btn-outline-secondary" title="Alternar tema">
            <i id="theme-icon" class="bi bi-sun-fill"></i>
          </button>
          <a href="<%= typeof viewUrl !== 'undefined' && viewUrl ? viewUrl : '/' %>" target="_blank" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-box-arrow-up-right"></i> Ver Site
          </a>
          <a href="/admin/logout" class="btn btn-sm btn-outline-danger">
            <i class="bi bi-box-arrow-right"></i> Sair
          </a>
        </div>
      </div>

      <div class="page-body">
        <% if (typeof flash !=='undefined' && flash.length> 0) { %>
          <% flash.forEach(function(f) { %>
            <div
              class="alert alert-<%= f.type === 'success' ? 'success' : 'danger' %> alert-dismissible d-flex align-items-center gap-2 mb-3">
              <i class="bi bi-<%= f.type === 'success' ? 'check-circle' : 'exclamation-circle' %>"></i>
              <%= f.msg %>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
            <% }) %>
              <% } %>