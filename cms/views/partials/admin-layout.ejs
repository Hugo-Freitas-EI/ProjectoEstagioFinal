<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' · ' : '' %>NodeCMS Admin</title>
<link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrap">

  <aside class="sidebar">
    <div class="sidebar-logo">
      <h1>NodeCMS</h1>
      <span>Painel Admin</span>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">Principal</div>
      <a href="/admin" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
        <span class="nav-icon">⊞</span><span>Dashboard</span>
      </a>

      <div class="nav-section">Conteúdo</div>
      <a href="/admin/posts" class="nav-item <%= currentPage === 'posts' ? 'active' : '' %>">
        <span class="nav-icon">✎</span><span>Posts</span>
      </a>
      <a href="/admin/pages" class="nav-item <%= currentPage === 'pages' ? 'active' : '' %>">
        <span class="nav-icon">☰</span><span>Páginas</span>
      </a>
      <a href="/admin/media" class="nav-item <%= currentPage === 'media' ? 'active' : '' %>">
        <span class="nav-icon">⊙</span><span>Media</span>
      </a>

      <div class="nav-section">Gestão</div>
      <a href="/admin/users" class="nav-item <%= currentPage === 'users' ? 'active' : '' %>">
        <span class="nav-icon">◉</span><span>Utilizadores</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <% if (user) { %>
        <div class="user-avatar" style="margin-bottom:8px"><%= user.username[0].toUpperCase() %></div>
        <div class="username"><%= user.username %></div>
        <div class="role"><%= user.role %></div>
      <% } %>
    </div>
  </aside>

  <div class="admin-main">
    <div class="topbar">
      <h2><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Admin' %></h2>
      <div class="topbar-actions">
        <a href="/" target="_blank" class="btn btn-ghost btn-sm">↗ Ver Site</a>
        <a href="/admin/logout" class="btn btn-ghost btn-sm">Sair</a>
      </div>
    </div>

    <div class="admin-content">

      <%# Flash messages %>
      <% if (typeof flash !== 'undefined' && flash.length > 0) { %>
        <% flash.forEach(function(f) { %>
          <div class="alert alert-<%= f.type === 'success' ? 'success' : 'error' %>" style="margin-bottom:16px;display:flex;align-items:center;gap:8px">
            <span><%= f.type === 'success' ? '✓' : '✕' %></span>
            <%= f.msg %>
          </div>
        <% }) %>
      <% } %>

