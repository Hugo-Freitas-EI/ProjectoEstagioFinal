    </div><!-- /.page-body -->
  </div><!-- /.main-content -->
</div>

<!-- Modal: alterações não guardadas -->
<div id="unsaved-modal" class="unsaved-overlay" role="dialog" aria-modal="true">
  <div class="unsaved-dialog">
    <h5>Quer sair do site?</h5>
    <p>É possível que as alterações não tenham sido efetuadas.</p>
    <div class="unsaved-actions">
      <button id="unsaved-leave" class="btn-leave">Sair</button>
      <button id="unsaved-stay" class="btn-stay">Cancelar</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/admin.js"></script>
</body>
</html>
